name: Check review-trail (AP-16)

# Layer 5 enforcement: блокирует merge PR без валидного review-trail.
# Defense-in-depth поверх Layer 4 (git pre-push hook).
#
# Setup в product repo:
#   1. Bootstrap-agent копирует этот файл в .github/workflows/check-review-trail.yml
#      на Stage D (адаптирует если product использует другой default branch).
#   2. Оператор настраивает branch protection rule на main:
#      Settings → Branches → main → Require status checks → "Check review-trail (AP-16)"
#      Без этого CI workflow существует, но merge всё равно возможен — branch protection
#      превращает status check в required check.
#
# Скрипт scripts/check-review-trail.sh должен быть установлен в product repo
# (bootstrap-agent копирует из doc/_templates/scripts/check-review-trail.sh.tmpl).

on:
  pull_request:
    types: [opened, synchronize, reopened]
    branches: [main, master]

jobs:
  check-review-trail:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout PR head
        uses: actions/checkout@v4
        with:
          ref: ${{ github.event.pull_request.head.sha }}
          fetch-depth: 1

      - name: Verify review-trail
        env:
          BRANCH: ${{ github.event.pull_request.head.ref }}
        run: |
          set -e
          if [ ! -x "scripts/check-review-trail.sh" ]; then
            echo "::error::scripts/check-review-trail.sh не найден или не executable."
            echo "::error::Bootstrap-agent должен был установить на Stage D из"
            echo "::error::doc/_templates/scripts/check-review-trail.sh.tmpl."
            exit 1
          fi
          scripts/check-review-trail.sh "$BRANCH"
