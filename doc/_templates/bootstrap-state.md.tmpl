# Mode — какой workflow используется сейчас. См. development-protocol.md § 3.
# new-product — greenfield bootstrap (Stage A-D formal)
# feature — новая фича (любое состояние проекта)
# rework — modify existing feature
# bug-fix — lite variant of feature
# template-sync — bump template version в template-native проекте
mode: new-product | feature | rework | bug-fix | template-sync
integration: gitignore | submodule | vendor
trust_profile: A                  # PM-only в v0. Поле сохранено для backward-compat (existing проекты с B/C accepted as A) и future расширения.
doc_root: doc | .ai-pm/doc        # top-level для new-product + feature/rework без existing doc/, иначе .ai-pm/doc/
primary_language: ru | en | other # язык project artifacts. AI переводит общие англицизмы; established техтермины (MVP, KDF, AEAD, WebAuthn) оставляет.
started: YYYY-MM-DD
last_update: YYYY-MM-DD

# Template versioning — SemVer (vMAJOR.MINOR.PATCH), tag в template repo.
# template_version_applied фиксирует какая версия шаблона применена сейчас.
# Сравнивается с latest tag при `template-sync` mode для diff'а.
template_version_applied: v0.X.Y

# Foundation state — orthogonal к mode. Определяет глубину AP-14 read-pass
# requirements. См. design doc в meta/design/2026-05-24_mode-matrix-and-adoption.md.
# complete — full Stage A-C filled (greenfield closed Stage D или legacy-staged completed)
# partial — некоторые Stage A-C artifacts есть, не все
# minimal — только Tier 0 auto-extract artifacts (legacy-quick adoption)
# none — только trust_profile + stack + Stage D hooks (legacy-skip adoption)
foundation_completeness: complete | partial | minimal | none

# Adoption path — как проект попал в текущее состояние foundation.
# greenfield — Stage A-D formal с нуля (через new-product mode)
# legacy-quick — Tier 0 auto-extract при legacy adoption (5-10 min)
# legacy-staged — operator multi-selected Stage A-D artifacts (часы-дни)
# legacy-skip — только minimum + Stage D hooks (sub-minute)
# null — для greenfield projects пока Stage D не closed
adoption_path: greenfield | legacy-quick | legacy-staged | legacy-skip | null

# Adoption overrides — declared trade-offs (Tier 3). Parallel к AP-16 review-override.
# Каждый entry требует reason + accepted-risk. AI не override'ит сам — только
# explicit operator instruction. См. AP-22 в anti-patterns.md.
adoption_overrides: []
# Example:
# adoption_overrides:
#   - skip: stage-e-hooks
#     reason: «legacy CI integration conflicts, hooks moved to separate PR»
#     accepted-risk: «AP-16 enforcement soft, manual review-trail discipline»
#     declared_at: YYYY-MM-DD
#     expires_at: YYYY-MM-DD  # optional sunset, force re-evaluation

stack: typescript | python | go | rust | ... | unknown
project_capabilities:
  - uses-crypto: yes | no
  - uses-auth: yes | no
  - uses-payments: yes | no
  - processes-pii: yes | no
  - uses-containers: yes | no
  - uses-i18n: yes | no
  - multi-tenant: yes | no
  - public-web: yes | no
  # ui_kind: формы UI продукта. Допустимые значения:
  # web, native-mobile, native-desktop, tui, cli, embedded, backend.
  # Multi-value для composite stacks ("web, backend"; "native-mobile, backend").
  # Default `tbd` на Init; заполняется на Stage A после vision artifact'а,
  # когда product shape clear. Additive evolution: добавление нового kind
  # позже — update поля + write новый ui-style-guide-<kind>.md.
  - ui_kind: tbd | <comma-separated list>
  # db_kind: формы БД продукта. Допустимые значения:
  # embedded, external, none.
  # Multi-value для composite stacks (e.g. "embedded, external" для mobile с
  # local cache + central API). `none` для stateless services / pure compute.
  # Определяет какие database-design-*.md файлы пишет bootstrap-agent.
  # Заполняется на Stage C вместе со stack choice. См. AP-18.
  - db_kind: tbd | none | <comma-separated list>

# === v0.4.0 additions: discipline-advisor + conditional skip framework ===

# Advisor preset — определяет how aggressive advisor рекомендует skip артефактов.
# Per-artifact override через adoption_overrides выше.
# - full (default для existing projects) — keep all artifacts. Backwards compat.
# - standard (default для новых проектов в v0.4.0+) — skip только conditional-no
#   (e.g., threat-model если все security capabilities = no)
# - minimal — агрессивно рекомендует skip всё что не hard floor (для weekend
#   projects / personal utilities)
advisor_preset: full | standard | minimal

# Skip decisions — log per-artifact decisions от advisor + operator confirmation.
# Расширяет adoption_overrides для finer granularity (per-artifact, не just stage).
# next_reprompt — для layer-climbing escalation (дыра 4 critique audit):
# operator подтвердил skip 90 дней назад → re-validate.
skip_decisions: []
# Example:
# skip_decisions:
#   - artifact: threat-model.md
#     state: skipped | active | mandatory-promoted
#     reason: «no security surface detected (uses-auth=no, processes-pii=no, ...)»
#     declared_at: YYYY-MM-DD
#     next_reprompt: YYYY-MM-DD  # default 90 days from declared_at
#     promoted_by: advisor-floor | quiz | operator
#   - artifact: customer-interview-script.md
#     state: skipped
#     reason: «internal tool, no external validation needed»
#     declared_at: YYYY-MM-DD
#     next_reprompt: YYYY-MM-DD
#     promoted_by: operator

# Advisor log — read-only trace of advisory triggers + findings + outcomes.
# Append-only, для audit trail.
advisor_log: []
# Example:
# advisor_log:
#   - timestamp: 2026-05-25T14:30:00Z
#     trigger: bootstrap-entry | preset-change | stage-f-entry | spec-draft | plan-draft | code-diff | review
#     axis: понятность | поддерживаемость | технические качество | UI | UX | learning
#     findings:
#       - "stripe.charges.create detected at src/payments/checkout.ts:42 → Stage B mandatory (hard floor)"
#       - "single-file utility detected → maintenance-playbook skip-safe"
#     applied: yes | no
