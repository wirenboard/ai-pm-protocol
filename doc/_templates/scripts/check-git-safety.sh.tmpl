#!/usr/bin/env bash
# scripts/check-git-safety.sh
# Layer 2 enforcement: блокирует опасные git-операции.
# Используется как PreToolUse hook в .claude/settings.json для Bash matcher'а.
#
# Hook input: JSON через stdin (Claude Code hook API):
#   { "tool_name": "Bash", "tool_input": { "command": "..." } }
#
# Exit codes:
#   0 — allow
#   2 — block (stderr передаётся AI обратно)
#
# Smoke-test:
#   echo '{"tool_name":"Bash","tool_input":{"command":"git push origin main"}}' | bash scripts/check-git-safety.sh

set -e

INPUT=$(cat)

if command -v jq >/dev/null 2>&1; then
  TOOL=$(echo "$INPUT" | jq -r '.tool_name // empty')
  CMD=$(echo "$INPUT" | jq -r '.tool_input.command // empty')
else
  TOOL=$(echo "$INPUT" | grep -oE '"tool_name"[[:space:]]*:[[:space:]]*"[^"]+"' | sed -E 's/.*:[[:space:]]*"([^"]+)"/\1/' | head -1)
  CMD=$(echo "$INPUT" | grep -oE '"command"[[:space:]]*:[[:space:]]*"[^"]+"' | sed -E 's/.*:[[:space:]]*"([^"]+)"/\1/' | head -1)
fi

[ "$TOOL" != "Bash" ] && exit 0
[ -z "$CMD" ] && exit 0

# 1. Direct push в main/master (allow --dry-run / --help)
if echo "$CMD" | grep -qE "git[[:space:]]+push.*\b(main|master)\b" && \
   ! echo "$CMD" | grep -qE "(--dry-run|--help)"; then
  echo "BLOCKED: direct git push в main/master запрещён." >&2
  echo "Используй PR-flow: создай feature branch, push туда, открой PR с squash & merge." >&2
  echo "См. development-protocol.md § 14." >&2
  exit 2
fi

# 2. --no-verify (skip hooks) — AP-6
if echo "$CMD" | grep -qE "git[[:space:]]+(commit|push)[[:space:]].*--no-verify"; then
  echo "BLOCKED: --no-verify запрещён по anti-pattern AP-6." >&2
  echo "Если pre-commit hook fail'ит, fix корень причины, не обходи hook." >&2
  exit 2
fi

# 3. Force push в main/master
if echo "$CMD" | grep -qE "git[[:space:]]+push.*[[:space:]](--force|--force-with-lease|-f)\b.*\b(main|master)\b"; then
  echo "BLOCKED: force push в main/master запрещён branch protection." >&2
  echo "Если нужно undo merged commit — делай revert через новый PR." >&2
  exit 2
fi

# 4. Прямой коммит в main (checkout + commit chained)
if echo "$CMD" | grep -qE "git[[:space:]]+checkout[[:space:]]+(main|master)" && \
   echo "$CMD" | grep -qE "&&.*git[[:space:]]+commit"; then
  echo "BLOCKED: попытка коммита в main/master напрямую." >&2
  echo "Создай feature branch для work." >&2
  exit 2
fi

# 5. git config user.* (изменение identity)
if echo "$CMD" | grep -qE "git[[:space:]]+config[[:space:]]+user\.(name|email)"; then
  echo "BLOCKED: изменение git user.name/user.email требует явного operator-approval." >&2
  echo "Если это нужно — оператор сделает руками или через explicit instruction." >&2
  exit 2
fi

exit 0
