#!/usr/bin/env bash
# scripts/bootstrap-verify.sh
# Stage E health-check (v0.3.0+). Replaces 12 granular checkboxes в bootstrap-state.md
# одной строкой "bootstrap-verify.sh passed" + script проверяет all 12 пунктов.
#
# Usage:
#   ./scripts/bootstrap-verify.sh           — verify all, output какой пункт failed
#   ./scripts/bootstrap-verify.sh --strict  — exit 1 при first failure (для CI)
#
# Exit codes:
#   0 — все пункты passed
#   1 — at least one пункт failed (или strict mode)
#
# Separation of concerns:
# - Validation (this script) — granular per-item checks
# - Tracking (bootstrap-state.md) — 1 coarse checkpoint
#
# См. AP-2 (no premature Stage E) — script запускается ТОЛЬКО после Stage A-D closed.

set -e

STRICT=0
[ "${1:-}" = "--strict" ] && STRICT=1

FAILED=0
WARNINGS=0
FAILED_ITEMS=()

log_fail() {
  echo "FAIL: $1" >&2
  FAILED=$((FAILED + 1))
  FAILED_ITEMS+=("$1")
  [ "$STRICT" -eq 1 ] && exit 1
}

log_warn() {
  echo "WARN: $1" >&2
  WARNINGS=$((WARNINGS + 1))
}

log_ok() {
  echo "OK: $1"
}

# Item 1: CI workflow
check_ci_workflow() {
  if [ -f ".github/workflows/ci.yml" ] || [ -f ".gitlab-ci.yml" ] || [ -f ".circleci/config.yml" ]; then
    log_ok "CI workflow generated"
  else
    log_fail "CI workflow generated — no CI config found (.github/workflows/ci.yml / .gitlab-ci.yml / .circleci/config.yml)"
  fi
}

# Item 2: linter configs
check_linter_configs() {
  local found=0
  for cfg in .eslintrc* .prettierrc* eslint.config.* prettier.config.* ruff.toml pyproject.toml .golangci.yml .golangci.yaml rustfmt.toml clippy.toml; do
    [ -f "$cfg" ] && { found=1; break; }
  done
  if [ "$found" -eq 1 ]; then
    log_ok "linter configs generated"
  else
    log_warn "linter configs generated — no common linter config found (stack-specific check optional)"
  fi
}

# Item 3: security tools
check_security_tools() {
  if [ -f ".gitleaks.toml" ] || [ -f ".pre-commit-config.yaml" ] || grep -q "gitleaks\|trivy\|grype\|snyk" .github/workflows/*.yml 2>/dev/null; then
    log_ok "security tools configured"
  else
    log_warn "security tools configured — no detected (gitleaks / trivy / pre-commit) — optional but recommended"
  fi
}

# Item 4: CLAUDE.md в product root
check_claude_md() {
  if [ -f "CLAUDE.md" ]; then
    log_ok "CLAUDE.md в product root"
  else
    log_fail "CLAUDE.md в product root — file missing (briefing для Claude sessions, Stage E required)"
  fi
}

# Item 5: .claude/settings.json + hooks
check_claude_settings() {
  if [ -f ".claude/settings.json" ]; then
    log_ok ".claude/settings.json + hooks"
  else
    log_fail ".claude/settings.json + hooks — Layer 2 enforcement hooks missing"
  fi
}

# Item 6: .gitignore содержит .ai-pm/.reviews/
check_gitignore() {
  if [ -f ".gitignore" ] && grep -q "\.ai-pm/\.reviews/" .gitignore; then
    log_ok ".gitignore: .ai-pm/.reviews/ добавлено"
  else
    log_fail ".gitignore: .ai-pm/.reviews/ entry missing (AP-16 local review-trace должен быть gitignored)"
  fi
}

# Item 7: auto-extract scripts
check_auto_extract() {
  local missing=()
  for script in extract-stack.sh extract-ui-kind.sh extract-db-kind.sh extract-topology.py extract-ui-style.py extract-database-design.py extract-all.sh; do
    [ -f "scripts/auto-extract/$script" ] || missing+=("$script")
  done
  if [ "${#missing[@]}" -eq 0 ]; then
    log_ok "auto-extract scripts generated"
  else
    log_fail "auto-extract scripts generated — missing: ${missing[*]}"
  fi
}

# Item 8: foundation maintenance scripts
check_maintenance_scripts() {
  local missing=()
  for script in promote-foundation.py template-sync-doc-migrate.py; do
    [ -f "scripts/$script" ] || missing+=("$script")
  done
  if [ "${#missing[@]}" -eq 0 ]; then
    log_ok "foundation maintenance scripts generated"
  else
    log_fail "foundation maintenance scripts generated — missing: ${missing[*]}"
  fi
}

# Item 9: git hooks installed (включая pre-push)
check_git_hooks() {
  if [ -f ".git/hooks/pre-push" ] || [ -f ".husky/pre-push" ]; then
    log_ok "git hooks installed (pre-push hard-block на main / master)"
  else
    log_fail "git hooks installed — pre-push hook missing (защита от direct push в main, AP-19 + § 14.6)"
  fi
}

# Item 10: branch protection enabled
check_branch_protection() {
  # Серверная (через gh) или клиентская (pre-push hook — уже checked в item 9)
  if command -v gh >/dev/null 2>&1; then
    if gh api "repos/$(gh repo view --json owner,name -q '.owner.login + \"/\" + .name')/branches/main/protection" >/dev/null 2>&1; then
      log_ok "branch protection enabled (серверная через gh)"
      return
    fi
  fi
  # Fallback: client-side pre-push hook (item 9 уже verified)
  log_warn "branch protection enabled — серверная не verified (gh API unavailable или нет API access); client-side pre-push hook должен быть в item 9"
}

# Item 11: Developer ergonomics scaffold
check_dev_ergonomics() {
  local found=0
  for f in Makefile justfile package.json; do
    [ -f "$f" ] && { found=1; break; }
  done
  if [ "$found" -eq 1 ] && [ -f ".editorconfig" ]; then
    log_ok "Developer ergonomics scaffold (Makefile/justfile/package.json + .editorconfig)"
  else
    log_fail "Developer ergonomics scaffold — missing Makefile/justfile/package.json или .editorconfig"
  fi
}

# Item 12: make setup && make test runs green
# (script only verifies presence of targets — не запускает их по умолчанию)
check_make_targets() {
  if [ -f "Makefile" ]; then
    local missing=()
    for target in setup test lint fmt; do
      grep -qE "^${target}:" Makefile || missing+=("$target")
    done
    if [ "${#missing[@]}" -eq 0 ]; then
      log_ok "Makefile содержит targets: setup, test, lint, fmt"
    else
      log_fail "Makefile targets missing: ${missing[*]}"
    fi
  elif [ -f "package.json" ]; then
    if grep -q '"setup"\|"test"' package.json; then
      log_ok "package.json содержит setup / test scripts"
    else
      log_fail "package.json — setup / test scripts missing"
    fi
  else
    log_warn "make / package.json setup verification — no Makefile или package.json (stack-specific check optional)"
  fi
}

# === Main ===
echo "Stage E bootstrap verification (v0.3.0+)"
echo "========================================"

check_ci_workflow
check_linter_configs
check_security_tools
check_claude_md
check_claude_settings
check_gitignore
check_auto_extract
check_maintenance_scripts
check_git_hooks
check_branch_protection
check_dev_ergonomics
check_make_targets

echo ""
echo "Summary: $FAILED FAILED, $WARNINGS WARNINGS"

if [ "$FAILED" -gt 0 ]; then
  echo ""
  echo "FAILED items:"
  for item in "${FAILED_ITEMS[@]}"; do
    echo "  - $item"
  done
  echo ""
  echo "Stage E не closed. Fix failed items и re-run."
  exit 1
fi

echo ""
echo "Stage E verified — все granular пункты passed. Update .bootstrap-state.md:"
echo "  - [x] bootstrap-verify.sh passed ($(date +%Y-%m-%d))"
exit 0
