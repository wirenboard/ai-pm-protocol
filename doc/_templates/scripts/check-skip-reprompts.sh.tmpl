#!/usr/bin/env bash
# scripts/check-skip-reprompts.sh
#
# Layer-climbing escalation для skip_decisions. Парсит skip_decisions block в
# .ai-pm/.bootstrap-state.md, сверяет next_reprompt с today, печатает expired
# skip'ы для оператора.
#
# Раньше (pre-v0.7.0) "advisor возвращается через 90 дней пересмотреть skip"
# описывалось только в discipline-advisor.md промпте — полагались на то что
# advisor invoke'нется и вспомнит. С v0.7.0 (advisor retired в agent-consolidation
# feature) — этот deterministic check единственный mechanism. Вызывается из
# SessionStart hook / pre-commit warning / bootstrap entry / CI.
#
# Usage:
#   ./check-skip-reprompts.sh           — human warning на stderr, exit 0 (non-blocking)
#   ./check-skip-reprompts.sh --json    — JSON list expired skips на stdout
#   ./check-skip-reprompts.sh --strict  — exit 1 если есть expired (для CI gate)
#
# Format в bootstrap-state.md (YAML-в-markdown):
#   skip_decisions:
#     - artifact: threat-model.md
#       state: skipped | active | mandatory-promoted
#       reason: "..."
#       declared_at: YYYY-MM-DD
#       next_reprompt: YYYY-MM-DD
#       promoted_by: advisor-floor | quiz | operator

set -e

MODE="human"
STRICT=0

while [ $# -gt 0 ]; do
  case "$1" in
    --json)   MODE="json" ;;
    --strict) STRICT=1 ;;
    -h|--help)
      sed -n '2,20p' "$0" >&2
      exit 0
      ;;
    *)
      echo "Unknown arg: $1" >&2
      exit 2
      ;;
  esac
  shift
done

STATE_FILE=""
for candidate in ".ai-pm/.bootstrap-state.md" ".bootstrap-state.md"; do
  if [ -f "$candidate" ]; then
    STATE_FILE="$candidate"
    break
  fi
done

if [ -z "$STATE_FILE" ]; then
  # No state file → no skip_decisions → nothing to remind about
  [ "$MODE" = "json" ] && echo "[]"
  exit 0
fi

TODAY=$(date +%Y-%m-%d)

# Extract skip_decisions block (от строки `skip_decisions:` до следующего top-level key).
# Top-level keys identified as: ^[a-z_]+: (start of line, no leading whitespace).
BLOCK=$(awk '
  /^skip_decisions:/ { in_block = 1; print; next }
  in_block && /^[a-z_][a-z_]*:/ { in_block = 0 }
  in_block { print }
' "$STATE_FILE")

# Parse YAML list entries. Каждый entry начинается с "  - " (или с "- ").
# Собираем поля artifact и next_reprompt per entry.
EXPIRED=$(printf '%s\n' "$BLOCK" | awk -v today="$TODAY" '
  /^[[:space:]]*-[[:space:]]+/ {
    if (artifact && reprompt && reprompt < today) {
      printf "%s\t%s\t%s\n", artifact, reprompt, reason
    }
    artifact = ""; reprompt = ""; reason = ""
  }
  /artifact:/ {
    sub(/^[[:space:]]*-?[[:space:]]*artifact:[[:space:]]*/, "")
    sub(/[[:space:]]*$/, "")
    gsub(/"/, "")
    artifact = $0
  }
  /next_reprompt:/ {
    sub(/^[[:space:]]*next_reprompt:[[:space:]]*/, "")
    sub(/[[:space:]].*$/, "")
    reprompt = $0
  }
  /reason:/ {
    sub(/^[[:space:]]*reason:[[:space:]]*/, "")
    sub(/[[:space:]]*$/, "")
    gsub(/"/, "")
    reason = $0
  }
  END {
    if (artifact && reprompt && reprompt < today) {
      printf "%s\t%s\t%s\n", artifact, reprompt, reason
    }
  }
')

if [ "$MODE" = "json" ]; then
  printf '['
  first=1
  printf '%s\n' "$EXPIRED" | while IFS=$'\t' read -r artifact reprompt reason; do
    [ -z "$artifact" ] && continue
    [ $first -eq 0 ] && printf ','
    # JSON-escape
    art_e="${artifact//\\/\\\\}"; art_e="${art_e//\"/\\\"}"
    rea_e="${reason//\\/\\\\}"; rea_e="${rea_e//\"/\\\"}"
    printf '{"artifact":"%s","next_reprompt":"%s","reason":"%s"}' "$art_e" "$reprompt" "$rea_e"
    first=0
  done
  echo ']'
else
  COUNT=0
  while IFS=$'\t' read -r artifact reprompt reason; do
    [ -z "$artifact" ] && continue
    if [ $COUNT -eq 0 ]; then
      echo "" >&2
      echo "=== Skip reprompts — время пересмотреть ===" >&2
      echo "" >&2
    fi
    COUNT=$((COUNT + 1))
    echo "  $artifact (skip declared, next_reprompt: $reprompt < today $TODAY)" >&2
    [ -n "$reason" ] && echo "    причина skip'а: $reason" >&2
  done <<< "$EXPIRED"
  if [ $COUNT -gt 0 ]; then
    echo "" >&2
    echo "Спросить advisor: «зависимости / threats не изменились?» Решение — оператор." >&2
    echo "После re-validation обновить next_reprompt в .ai-pm/.bootstrap-state.md." >&2
    echo "" >&2
  fi
fi

# Strict mode для CI gate
if [ $STRICT -eq 1 ] && [ -n "$EXPIRED" ] && [ "$(echo "$EXPIRED" | grep -c .)" -gt 0 ]; then
  exit 1
fi

exit 0
