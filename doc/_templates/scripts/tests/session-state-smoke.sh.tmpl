#!/usr/bin/env bash
# scripts/tests/session-state-smoke.sh
#
# Smoke tests для session-resume-state feature:
#   - scripts/update-session-state.sh   (PostToolUse handler)
#   - scripts/print-session-state.sh    (SessionStart handler)
#
# Запуск (из product repo root):
#   bash scripts/tests/session-state-smoke.sh
#
# Каждый test создаёт изолированный временный sandbox с фейковым git repo,
# вызывает скрипты на синтетических stdin JSON'ах, проверяет state-файл
# / output / exit code. На любой fail — `exit 1` + диагностика в stderr.
#
# Exit:
#   0 — все 9 cases прошли
#   1 — хотя бы один fail

set -u

# === paths ===
# Скрипт лежит в scripts/tests/, hooks — в scripts/. Resolve absolute, чтобы cd в sandbox
# не сломал относительные пути.
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SCRIPTS_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
UPDATE="$SCRIPTS_DIR/update-session-state.sh"
PRINT="$SCRIPTS_DIR/print-session-state.sh"

PASS=0
FAIL=0
FAILED_TESTS=()

run() {
  local name="$1"; shift
  local fn="$1"; shift
  local sandbox
  sandbox=$(mktemp -d -t session-state-smoke.XXXXXX)
  (
    cd "$sandbox" || exit 99
    git init -q
    git config user.email "test@example.com"
    git config user.name "Test"
    git checkout -q -b feature/foo 2>/dev/null || git checkout -q feature/foo
    mkdir -p .ai-pm
    "$fn"
  )
  local rc=$?
  rm -rf "$sandbox"
  if [ $rc -eq 0 ]; then
    PASS=$((PASS + 1))
    printf '  [PASS] %s\n' "$name"
  else
    FAIL=$((FAIL + 1))
    FAILED_TESTS+=("$name")
    printf '  [FAIL] %s\n' "$name" >&2
  fi
}

# Helper assertions для under-sandbox функций. Каждая печатает диагностику + exit 1.
assert_file_exists() {
  local f="$1"
  if [ ! -f "$f" ]; then
    echo "    expected file $f to exist" >&2
    exit 1
  fi
}

assert_grep() {
  local file="$1"; local pattern="$2"
  if ! grep -qE "$pattern" "$file"; then
    echo "    expected pattern '$pattern' in $file:" >&2
    sed -n '1,40p' "$file" >&2
    exit 1
  fi
}

assert_no_grep() {
  local file="$1"; local pattern="$2"
  if grep -qE "$pattern" "$file"; then
    echo "    pattern '$pattern' should NOT match $file" >&2
    exit 1
  fi
}

# === Test 1: spec write → step 1 ===
test_spec_write() {
  echo '{"tool_name":"Write","tool_input":{"file_path":"doc/features/foo_spec.md"}}' | bash "$UPDATE"
  assert_file_exists ".ai-pm/.session-state.md"
  assert_grep ".ai-pm/.session-state.md" "^current_topic: foo$"
  assert_grep ".ai-pm/.session-state.md" "^current_step: 1"
  assert_grep ".ai-pm/.session-state.md" "^current_branch: feature/foo$"
  assert_grep ".ai-pm/.session-state.md" "^last_update: [0-9]{4}-[0-9]{2}-[0-9]{2}T"
}

# === Test 2: plan write → step 2 ===
test_plan_write() {
  echo '{"tool_name":"Edit","tool_input":{"file_path":".ai-pm/doc/features/foo_plan.md"}}' | bash "$UPDATE"
  assert_grep ".ai-pm/.session-state.md" "^current_step: 2"
  assert_grep ".ai-pm/.session-state.md" "^current_topic: foo$"
}

# === Test 3: code write → step 4, topic preserved ===
test_code_write_preserves_topic() {
  # Seed: pretend a spec write happened earlier
  echo '{"tool_name":"Write","tool_input":{"file_path":"doc/features/foo_spec.md"}}' | bash "$UPDATE"
  echo '{"tool_name":"Write","tool_input":{"file_path":"apps/web/src/auth.ts"}}' | bash "$UPDATE"
  assert_grep ".ai-pm/.session-state.md" "^current_step: 4"
  assert_grep ".ai-pm/.session-state.md" "^current_topic: foo$"
}

# === Test 4: non-feature write → state unchanged ===
test_non_feature_write_skips() {
  echo '{"tool_name":"Write","tool_input":{"file_path":"doc/features/foo_spec.md"}}' | bash "$UPDATE"
  local before
  before=$(cat .ai-pm/.session-state.md)
  # sleep 1 sec to ensure timestamp diff would show up if hook wrote
  sleep 1
  echo '{"tool_name":"Write","tool_input":{"file_path":"README.md"}}' | bash "$UPDATE"
  local after
  after=$(cat .ai-pm/.session-state.md)
  if [ "$before" != "$after" ]; then
    echo "    state file should be unchanged after non-feature write" >&2
    diff <(echo "$before") <(echo "$after") >&2
    exit 1
  fi
}

# === Test 5: invalid JSON → exit 0, no crash ===
test_invalid_json() {
  if ! echo 'not json at all' | bash "$UPDATE"; then
    echo "    update-session-state.sh должен exit 0 даже на invalid JSON" >&2
    exit 1
  fi
  # Файл не должен быть создан если ничего не распознано
  if [ -f .ai-pm/.session-state.md ]; then
    echo "    state file не должен создаваться на invalid JSON" >&2
    exit 1
  fi
}

# === Test 6: review write → step 7 ===
test_review_write() {
  echo '{"tool_name":"Write","tool_input":{"file_path":"doc/features/foo_review.md"}}' | bash "$UPDATE"
  assert_grep ".ai-pm/.session-state.md" "^current_step: 7"
}

# === Test 7: print existing state ===
test_print_existing() {
  echo '{"tool_name":"Write","tool_input":{"file_path":"doc/features/foo_spec.md"}}' | bash "$UPDATE"
  local out
  out=$(bash "$PRINT" 2>&1 >/dev/null)
  if ! echo "$out" | grep -qE "current_topic: foo"; then
    echo "    print-session-state.sh должен напечатать 'current_topic: foo' в stderr" >&2
    echo "    actual stderr:" >&2
    echo "$out" >&2
    exit 1
  fi
}

# === Test 8: print missing file → fallback ===
test_print_missing() {
  rm -f .ai-pm/.session-state.md
  local out
  if ! out=$(bash "$PRINT" 2>&1 >/dev/null); then
    echo "    print-session-state.sh должен exit 0 при отсутствии файла" >&2
    exit 1
  fi
  if ! echo "$out" | grep -qE "session state"; then
    echo "    print-session-state.sh должен напечатать fallback message" >&2
    echo "    actual stderr:" >&2
    echo "$out" >&2
    exit 1
  fi
}

# === Test 9: preserves operator-managed (semantic) fields ===
test_preserves_semantic_fields() {
  # Seed initial state via hook
  echo '{"tool_name":"Write","tool_input":{"file_path":"doc/features/foo_spec.md"}}' | bash "$UPDATE"
  # Operator вручную добавил pending_agents block
  cat >> .ai-pm/.session-state.md <<'EOF'

pending_agents:
  - role: planner
    started_at: 2026-05-24T21:00:00Z
    expected_output: doc/features/foo_plan.md
    notes: "extracting 5 ADRs"

blocker: waiting for operator-acceptance
EOF
  # Hook вызывается снова (другой step)
  echo '{"tool_name":"Edit","tool_input":{"file_path":"doc/features/foo_plan.md"}}' | bash "$UPDATE"
  # Mechanical поле обновилось
  assert_grep ".ai-pm/.session-state.md" "^current_step: 2"
  # Semantic поля сохранились
  assert_grep ".ai-pm/.session-state.md" "^pending_agents:"
  assert_grep ".ai-pm/.session-state.md" "role: planner"
  assert_grep ".ai-pm/.session-state.md" "^blocker: waiting for operator-acceptance"
}

# === main ===

if [ ! -x "$UPDATE" ] && [ ! -f "$UPDATE" ]; then
  echo "ERROR: $UPDATE не найден. Установлен ли scripts/update-session-state.sh?" >&2
  exit 2
fi
if [ ! -x "$PRINT" ] && [ ! -f "$PRINT" ]; then
  echo "ERROR: $PRINT не найден. Установлен ли scripts/print-session-state.sh?" >&2
  exit 2
fi

echo "session-state smoke tests:"
run "1. spec write → step 1"                test_spec_write
run "2. plan write → step 2"                test_plan_write
run "3. code write preserves topic"         test_code_write_preserves_topic
run "4. non-feature write skips state"      test_non_feature_write_skips
run "5. invalid JSON exit 0, no crash"      test_invalid_json
run "6. review write → step 7"              test_review_write
run "7. print existing state to stderr"     test_print_existing
run "8. print missing file fallback"        test_print_missing
run "9. semantic fields preserved"          test_preserves_semantic_fields

echo ""
echo "results: $PASS passed, $FAIL failed"
if [ $FAIL -gt 0 ]; then
  echo "failed tests:" >&2
  for t in "${FAILED_TESTS[@]}"; do echo "  - $t" >&2; done
  exit 1
fi
exit 0
