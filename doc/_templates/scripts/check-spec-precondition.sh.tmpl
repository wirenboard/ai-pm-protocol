#!/usr/bin/env bash
# .ai-pm/tooling/scripts/check-spec-precondition.sh
# Layer 2 enforcement: blocks Write/Edit в code paths без соответствующего spec'а.
# Используется как PreToolUse hook в .claude/settings.json.
#
# Bootstrap-agent копирует этот skeleton на Stage E и адаптирует под layout проекта.
#
# Input через env vars (Claude Code hook interface):
#   CLAUDE_TOOL_NAME       — "Write" или "Edit"
#   CLAUDE_TOOL_PARAM_FILE — путь к файлу, который AI собирается изменить
#
# Output: exit 0 = allow; exit 1 + STDERR message = block.

set -e

FILE="${CLAUDE_TOOL_PARAM_FILE:-}"
if [ -z "$FILE" ]; then
  exit 0  # не file-modifying tool — пропускаем
fi

# Code paths, требующие spec'а перед изменением.
# Адаптируется под стек проекта на Stage E.
# Default: apps/, packages/, src/, lib/.
CODE_PATTERNS=(
  "^apps/"
  "^packages/"
  "^src/"
  "^lib/"
)

# Проверяем, попадает ли $FILE в code-path
IS_CODE=0
for pattern in "${CODE_PATTERNS[@]}"; do
  if echo "$FILE" | grep -qE "$pattern"; then
    IS_CODE=1
    break
  fi
done

if [ $IS_CODE -eq 0 ]; then
  exit 0  # не code-файл, hook не применим
fi

# Получаем текущую git-ветку
BRANCH=$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo "")
if [ "$BRANCH" = "main" ] || [ "$BRANCH" = "master" ]; then
  echo "BLOCKED: прямое изменение кода в main/master ветке запрещено." >&2
  echo "Создай feature/<topic> branch и работай там. См. development-protocol.md § 14." >&2
  exit 1
fi

# Extracting topic из ветки: feature/<topic> → <topic>
TOPIC=""
if echo "$BRANCH" | grep -qE "^feature/"; then
  TOPIC="${BRANCH#feature/}"
fi

if [ -z "$TOPIC" ]; then
  echo "BLOCKED: текущая ветка '$BRANCH' не следует convention feature/<topic>." >&2
  echo "См. development-protocol.md § 14.1." >&2
  exit 1
fi

# Проверяем наличие spec'а для topic'а
SPEC=".ai-pm/doc/features/${TOPIC}_spec.md"
if [ ! -f "$SPEC" ]; then
  echo "BLOCKED: попытка изменить '$FILE' без соответствующего spec'а." >&2
  echo "Expected: $SPEC" >&2
  echo "" >&2
  echo "По протоколу (AP-4 Specification First) код пишется только после approved spec'а." >&2
  echo "Шаги:" >&2
  echo "  1. Invoke planner для написания spec'а: 'invoke planner-agent для topic $TOPIC'." >&2
  echo "  2. operator-approval спека." >&2
  echo "  3. После approval'а — можешь редактировать код." >&2
  exit 1
fi

# Spec есть — проверим что approved (heuristic: оператор написал "approved" or "ок" в footer)
if ! grep -qE "(approved|ок|поехали|спека ок)" "$SPEC"; then
  echo "WARN: spec $SPEC существует, но не похоже что approved оператором." >&2
  echo "Если только что написан — оператор должен зафиксировать approval в spec.md или в commit message." >&2
  # Это warning, не block — позволяем продолжать в случае нестандартного формата approval'а
fi

exit 0
