#!/usr/bin/env bash
# scripts/check-spec-precondition.sh
# Layer 2 enforcement: блокирует Write/Edit в code paths без соответствующего spec'а (AP-4).
# Используется как PreToolUse hook в .claude/settings.json для Write|Edit matcher'а.
#
# Bootstrap-agent копирует этот skeleton на Stage D и адаптирует CODE_PATTERNS под layout проекта.
#
# Hook input: JSON через stdin (Claude Code hook API):
#   { "tool_name": "Write|Edit", "tool_input": { "file_path": "..." } }
#
# Exit codes:
#   0 — allow
#   2 — block (stderr передаётся AI обратно)
#
# Smoke-test:
#   echo '{"tool_name":"Write","tool_input":{"file_path":"src/index.ts"}}' | bash scripts/check-spec-precondition.sh

set -e

INPUT=$(cat)

if command -v jq >/dev/null 2>&1; then
  TOOL=$(echo "$INPUT" | jq -r '.tool_name // empty')
  FILE=$(echo "$INPUT" | jq -r '.tool_input.file_path // empty')
else
  TOOL=$(echo "$INPUT" | grep -oE '"tool_name"[[:space:]]*:[[:space:]]*"[^"]+"' | sed -E 's/.*:[[:space:]]*"([^"]+)"/\1/' | head -1)
  FILE=$(echo "$INPUT" | grep -oE '"file_path"[[:space:]]*:[[:space:]]*"[^"]+"' | sed -E 's/.*:[[:space:]]*"([^"]+)"/\1/' | head -1)
fi

# Не Write/Edit — пропускаем (на случай matcher misconfiguration)
case "$TOOL" in
  Write|Edit) ;;
  *) exit 0 ;;
esac

# Не file-modifying call (пустой file_path) — пропускаем
[ -z "$FILE" ] && exit 0

# Code paths, требующие spec'а перед изменением.
# Адаптируется под стек проекта на Stage D.
CODE_PATTERNS=(
  "^apps/"
  "^packages/"
  "^src/"
  "^lib/"
)

IS_CODE=0
for pattern in "${CODE_PATTERNS[@]}"; do
  if echo "$FILE" | grep -qE "$pattern"; then
    IS_CODE=1
    break
  fi
done

[ $IS_CODE -eq 0 ] && exit 0

BRANCH=$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo "")
if [ "$BRANCH" = "main" ] || [ "$BRANCH" = "master" ]; then
  echo "BLOCKED: прямое изменение кода в main/master ветке запрещено." >&2
  echo "Создай feature/<topic> branch и работай там. См. development-protocol.md § 14." >&2
  exit 2
fi

# feature/<topic> или feat/<topic>
TOPIC=""
case "$BRANCH" in
  feature/*) TOPIC="${BRANCH#feature/}" ;;
  feat/*)    TOPIC="${BRANCH#feat/}" ;;
esac

if [ -z "$TOPIC" ]; then
  echo "BLOCKED: текущая ветка '$BRANCH' не следует convention feature/<topic> или feat/<topic>." >&2
  echo "См. development-protocol.md § 14.1." >&2
  exit 2
fi

# Spec может лежать в doc/features/ (new-product) или .ai-pm/doc/features/ (retrofit layout)
SPEC=""
for candidate in "doc/features/${TOPIC}_spec.md" ".ai-pm/doc/features/${TOPIC}_spec.md"; do
  if [ -f "$candidate" ]; then
    SPEC="$candidate"
    break
  fi
done

if [ -z "$SPEC" ]; then
  echo "BLOCKED: попытка изменить '$FILE' без соответствующего spec'а." >&2
  echo "Expected: doc/features/${TOPIC}_spec.md (или .ai-pm/doc/features/${TOPIC}_spec.md)" >&2
  echo "" >&2
  echo "По протоколу (AP-4 Specification First) код пишется только после approved spec'а." >&2
  echo "Шаги:" >&2
  echo "  1. Invoke planner для написания spec'а: 'invoke planner-agent для topic ${TOPIC}'." >&2
  echo "  2. operator-approval спека." >&2
  echo "  3. После approval'а — можешь редактировать код." >&2
  exit 2
fi

# Spec есть — soft-check approval (heuristic). Не блокирующий — позволяем нестандартный формат.
if ! grep -qE "(approved|ок|поехали|спека ок)" "$SPEC"; then
  echo "WARN: spec $SPEC существует, но не похоже что approved оператором." >&2
  echo "Если только что написан — оператор должен зафиксировать approval в spec.md или в commit message." >&2
fi

exit 0
