#!/usr/bin/env bash
# scripts/update-bootstrap-state.sh
# Used as PostToolUse hook — после Write/Edit в .ai-pm/doc/features/ обновляет
# .ai-pm/.bootstrap-state.md timestamp. Audit trail активности для resume сессий.
#
# Hook input: JSON через stdin (Claude Code hook API):
#   { "tool_name": "Write|Edit", "tool_input": { "file_path": "..." } }
#
# PostToolUse hooks не блокируют tool execution — exit code informational.
#
# Smoke-test:
#   echo '{"tool_name":"Write","tool_input":{"file_path":".ai-pm/doc/features/signup_spec.md"}}' \
#     | bash scripts/update-bootstrap-state.sh

set -e

INPUT=$(cat)

if command -v jq >/dev/null 2>&1; then
  FILE=$(echo "$INPUT" | jq -r '.tool_input.file_path // empty')
else
  FILE=$(echo "$INPUT" | grep -oE '"file_path"[[:space:]]*:[[:space:]]*"[^"]+"' | sed -E 's/.*:[[:space:]]*"([^"]+)"/\1/' | head -1)
fi

[ -z "$FILE" ] && exit 0

# Только реагируем на изменения в .ai-pm/doc/ (или doc/ для new-product top-level layout)
if ! echo "$FILE" | grep -qE "^(\.ai-pm/)?doc/features/"; then
  exit 0
fi

STATE=".ai-pm/.bootstrap-state.md"
[ ! -f "$STATE" ] && exit 0  # state файла нет — не наша задача создавать

TIMESTAMP=$(date +%Y-%m-%d)

# Frontmatter `last_update: ...` поле (canonical), либо `**Last update:** ...` в body как fallback
if grep -qE "^last_update:" "$STATE"; then
  sed -i.bak -E "s/^last_update:.*$/last_update: ${TIMESTAMP}/" "$STATE" && rm -f "$STATE.bak"
elif grep -qE "^\*\*Last update:\*\*" "$STATE"; then
  sed -i.bak -E "s/^\*\*Last update:\*\*.*$/\*\*Last update:\*\* ${TIMESTAMP}/" "$STATE" && rm -f "$STATE.bak"
fi
# Если ни поля, ни bold-формы — silently no-op (state file без timestamp tracking, не ошибка)

exit 0
