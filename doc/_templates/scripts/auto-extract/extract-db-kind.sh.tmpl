#!/usr/bin/env bash
# .ai-pm/tooling/scripts/auto-extract/extract-db-kind.sh
# Tier 0 auto-extract — detects db_kind(s) via package deps heuristic.
#
# Output: comma-separated list (e.g., "embedded, external") или "none" / "unknown"
#
# Heuristic:
#   embedded  — sqlite, better-sqlite3, rusqlite, embedded duckdb, kv stores с file backend
#   external  — pg, mysql2, mongodb, redis client, prisma/drizzle/sqlalchemy с external URL
#   none      — нет DB deps detected (likely stateless / pure compute)

set -e

declare -a KINDS

# Node ecosystem
if [ -f package.json ]; then
  DEPS=$(grep -oE '"[a-zA-Z0-9@/_-]+"\s*:\s*"' package.json | grep -oE '"[a-zA-Z0-9@/_-]+"' | tr -d '"' || true)

  echo "$DEPS" | grep -qE '^(better-sqlite3|sqlite3|@libsql/client|kysely|sql\.js)$' && KINDS+=("embedded")
  echo "$DEPS" | grep -qE '^(pg|postgres|mysql2|mysql|mongodb|mongoose|redis|ioredis|@elastic/elasticsearch)$' && KINDS+=("external")
  echo "$DEPS" | grep -qE '^(prisma|@prisma/client|drizzle-orm|typeorm|sequelize|knex)$' && KINDS+=("external")  # ORMs обычно для external; check schema для уточнения
fi

# Python
if [ -f pyproject.toml ] || [ -f requirements.txt ]; then
  PY_DEPS=$(cat pyproject.toml requirements.txt 2>/dev/null | grep -oE '^[a-zA-Z0-9_-]+' | tr '[:upper:]' '[:lower:]' || true)

  echo "$PY_DEPS" | grep -qE '^(sqlite3|aiosqlite)$' && KINDS+=("embedded")
  echo "$PY_DEPS" | grep -qE '^(psycopg2|psycopg|asyncpg|pymysql|aiomysql|pymongo|motor|redis|aioredis)$' && KINDS+=("external")
  echo "$PY_DEPS" | grep -qE '^(sqlalchemy|tortoise-orm|peewee)$' && {
    # Check для sqlite URL в config
    if grep -rE "sqlite:///" . --include="*.py" --include="*.toml" --include="*.cfg" 2>/dev/null | head -1 | grep -q sqlite; then
      KINDS+=("embedded")
    else
      KINDS+=("external")
    fi
  }
fi

# Go
if [ -f go.mod ]; then
  GO_DEPS=$(grep -oE '[a-zA-Z0-9./_-]+' go.mod || true)

  echo "$GO_DEPS" | grep -qE 'mattn/go-sqlite3|modernc.org/sqlite' && KINDS+=("embedded")
  echo "$GO_DEPS" | grep -qE 'lib/pq|jackc/pgx|go-sql-driver/mysql|mongo-go-driver|redis/go-redis' && KINDS+=("external")
fi

# Rust
if [ -f Cargo.toml ]; then
  CARGO_DEPS=$(grep -oE '^[a-zA-Z0-9_-]+\s*=' Cargo.toml | grep -oE '^[a-zA-Z0-9_-]+' || true)

  echo "$CARGO_DEPS" | grep -qE '^(rusqlite|sqlx)$' && {
    # sqlx может быть для multiple DBs; check features
    if grep -qE 'sqlite' Cargo.toml; then
      KINDS+=("embedded")
    fi
    if grep -qE 'postgres|mysql' Cargo.toml; then
      KINDS+=("external")
    fi
  }
  echo "$CARGO_DEPS" | grep -qE '^(tokio-postgres|mongodb|redis)$' && KINDS+=("external")
fi

# Check Prisma schema для уточнения (override ORM heuristic)
if [ -f prisma/schema.prisma ]; then
  if grep -qE 'provider\s*=\s*"sqlite"' prisma/schema.prisma; then
    KINDS+=("embedded")
  elif grep -qE 'provider\s*=\s*"postgresql|mysql|mongodb"' prisma/schema.prisma; then
    KINDS+=("external")
  fi
fi

# Migrations dir hint
[ -d migrations ] && [ "${#KINDS[@]}" -eq 0 ] && KINDS+=("external")  # обычно external если есть migrations и нет других signals

# Dedupe
declare -a UNIQ
for k in "${KINDS[@]:-}"; do
  [ -z "$k" ] && continue
  found=0
  for u in "${UNIQ[@]:-}"; do
    [ "$k" = "$u" ] && found=1 && break
  done
  [ "$found" = "0" ] && UNIQ+=("$k")
done

if [ "${#UNIQ[@]}" -eq 0 ]; then
  echo "none"  # нет DB deps detected → likely stateless
else
  (IFS=,; echo "${UNIQ[*]}")
fi
