#!/usr/bin/env python3
"""
.ai-pm/tooling/scripts/auto-extract/extract-topology.py

Tier 0 auto-extract — generates topology.md sketch from filesystem + imports.

Usage:
    python3 extract-topology.py [--output <path>] [--root <dir>]

Defaults:
    --output: doc/topology.md (или .ai-pm/doc/topology.md если doc_root=.ai-pm/doc)
    --root: . (current directory)

Output: markdown с auto-extracted components, dependencies, structure.
Operator marker «<!-- Auto-extracted YYYY-MM-DD. Refine manually. -->» в начале.

Implementation:
    1. Walk filesystem, identify top-level directories (excluding common ignores).
    2. For each directory — detect language (по primary extensions) и top-level role.
    3. Build dependency graph через parse imports/requires (best-effort per language).
    4. Generate markdown.

Heuristic, не AST-perfect. Operator должен refine после extract.
"""

import argparse
import os
import re
import sys
from datetime import date
from pathlib import Path
from collections import defaultdict

# Standard ignores
IGNORE_DIRS = {
    'node_modules', '.git', '.venv', 'venv', '__pycache__', 'target',
    'build', 'dist', '.next', '.nuxt', 'out', '.cache', '.parcel-cache',
    'coverage', '.pytest_cache', '.mypy_cache', '.tox', 'vendor',
    '.idea', '.vscode', '.terraform', '.gradle', '.bundle',
    'node_modules', '.svelte-kit', '.expo',
}

# Language detection by extension
LANG_EXT = {
    '.ts': 'typescript', '.tsx': 'typescript',
    '.js': 'javascript', '.jsx': 'javascript', '.mjs': 'javascript',
    '.py': 'python',
    '.go': 'go',
    '.rs': 'rust',
    '.rb': 'ruby',
    '.java': 'java', '.kt': 'kotlin',
    '.php': 'php',
    '.ex': 'elixir', '.exs': 'elixir',
    '.cs': 'csharp',
    '.swift': 'swift',
}

# Top-level role hints (folder name → role)
ROLE_HINTS = {
    'api': 'backend service',
    'server': 'backend service',
    'backend': 'backend service',
    'web': 'frontend (web)',
    'frontend': 'frontend',
    'client': 'frontend',
    'mobile': 'frontend (mobile)',
    'app': 'application (UI)',
    'apps': 'monorepo apps directory',
    'packages': 'monorepo packages directory',
    'lib': 'shared library',
    'libs': 'shared libraries',
    'shared': 'shared code',
    'common': 'shared utilities',
    'core': 'core domain logic',
    'cli': 'CLI tool',
    'scripts': 'utility scripts',
    'migrations': 'database migrations',
    'docs': 'documentation',
    'doc': 'documentation',
    'tests': 'test suite',
    'test': 'test suite',
    'spec': 'test specs',
    'e2e': 'end-to-end tests',
    'examples': 'example code',
    'public': 'static assets (web)',
    'assets': 'static assets',
    'config': 'configuration',
    'configs': 'configurations',
    'src': 'source code',
}


def walk_top_level(root: Path):
    """Returns list of top-level directories worth describing."""
    dirs = []
    for entry in sorted(root.iterdir()):
        if not entry.is_dir():
            continue
        if entry.name.startswith('.'):
            continue
        if entry.name in IGNORE_DIRS:
            continue
        dirs.append(entry)
    return dirs


def detect_language(dir_path: Path) -> str:
    """Detects primary language by file extensions in directory tree."""
    counts = defaultdict(int)
    for path in dir_path.rglob('*'):
        if not path.is_file():
            continue
        if any(part in IGNORE_DIRS or part.startswith('.') for part in path.parts):
            continue
        lang = LANG_EXT.get(path.suffix)
        if lang:
            counts[lang] += 1
    if not counts:
        return 'unknown'
    return max(counts, key=counts.get)


def detect_role(dir_name: str) -> str:
    return ROLE_HINTS.get(dir_name.lower(), '')


def extract_imports_ts(file_path: Path, root: Path):
    """Extracts cross-component imports from TypeScript/JavaScript files."""
    imports = set()
    pattern_import = re.compile(r"""import\s+(?:.+?\s+from\s+)?['"]([^'"]+)['"]""")
    pattern_require = re.compile(r"""require\s*\(\s*['"]([^'"]+)['"]""")
    try:
        text = file_path.read_text(encoding='utf-8', errors='ignore')
        for pat in (pattern_import, pattern_require):
            for match in pat.finditer(text):
                imp = match.group(1)
                # Only interested in relative imports или workspace packages
                if imp.startswith('.') or imp.startswith('@/'):
                    imports.add(imp)
    except Exception:
        pass
    return imports


def extract_imports_py(file_path: Path, root: Path):
    """Extracts cross-module imports from Python files."""
    imports = set()
    pattern_from = re.compile(r"""^from\s+([\w.]+)\s+import""", re.MULTILINE)
    pattern_import = re.compile(r"""^import\s+([\w.,\s]+)""", re.MULTILINE)
    try:
        text = file_path.read_text(encoding='utf-8', errors='ignore')
        for match in pattern_from.finditer(text):
            imports.add(match.group(1))
        for match in pattern_import.finditer(text):
            for name in match.group(1).split(','):
                imports.add(name.strip())
    except Exception:
        pass
    return imports


def detect_dependencies(dirs, root: Path):
    """Best-effort dependency edges between top-level dirs."""
    edges = set()
    dir_names = {d.name for d in dirs}

    for dir_path in dirs:
        lang = detect_language(dir_path)
        for file_path in dir_path.rglob('*'):
            if not file_path.is_file():
                continue
            if any(part in IGNORE_DIRS for part in file_path.parts):
                continue

            imports = set()
            if lang in ('typescript', 'javascript'):
                imports = extract_imports_ts(file_path, root)
            elif lang == 'python':
                imports = extract_imports_py(file_path, root)
            # other languages — skip for v0

            for imp in imports:
                # Heuristic: extract first directory-level component
                for other in dir_names:
                    if other == dir_path.name:
                        continue
                    if (f'/{other}/' in imp or imp.startswith(f'{other}/')
                            or imp.startswith(f'./{other}') or imp.startswith(f'../{other}')):
                        edges.add((dir_path.name, other))
                        break
    return edges


def generate_markdown(dirs, edges, doc_root):
    """Generates topology.md content."""
    today = date.today().isoformat()
    lines = []
    lines.append('# Topology (auto-extracted)')
    lines.append('')
    lines.append(f'<!-- Auto-extracted {today} via scripts/auto-extract/extract-topology.py. Operator may refine. -->')
    lines.append('')
    lines.append('## Components')
    lines.append('')

    if not dirs:
        lines.append('_No top-level component directories detected._')
    else:
        for dir_path in dirs:
            lang = detect_language(dir_path)
            role = detect_role(dir_path.name)
            role_str = f'{role}, ' if role else ''
            lines.append(f'- **{dir_path.name}/** — {role_str}primary language: `{lang}`')

    lines.append('')
    lines.append('## Dependencies')
    lines.append('')

    if not edges:
        lines.append('_No cross-component dependencies detected (best-effort scan)._')
    else:
        sorted_edges = sorted(edges)
        for src, dst in sorted_edges:
            lines.append(f'- {src} → {dst}')

    lines.append('')
    lines.append('## Notes')
    lines.append('')
    lines.append('- This is a **Tier 0 auto-extract** sketch. Operator should refine: add deployment topology, runtime boundaries, data flows, integration points.')
    lines.append('- Heuristic limitations: dependencies detected via regex on imports, not AST. False positives и misses возможны.')
    lines.append('- For multi-domain features (AP-19), this topology + Conventional Commits scope determine PR ordering recommendations.')

    return '\n'.join(lines) + '\n'


def main():
    parser = argparse.ArgumentParser()
    parser.add_argument('--root', default='.', help='Root directory (default: .)')
    parser.add_argument('--output', help='Output file path (default: doc/topology.md or .ai-pm/doc/topology.md)')
    args = parser.parse_args()

    root = Path(args.root).resolve()
    if not root.exists():
        print(f'Error: root {root} does not exist', file=sys.stderr)
        sys.exit(1)

    # Determine output path
    if args.output:
        output_path = Path(args.output)
    else:
        # Read .ai-pm/.bootstrap-state.md if exists, get doc_root
        state_file = root / '.ai-pm' / '.bootstrap-state.md'
        doc_root = 'doc'
        if state_file.exists():
            for line in state_file.read_text(encoding='utf-8').splitlines():
                if line.startswith('doc_root:'):
                    doc_root = line.split(':', 1)[1].strip()
                    break
        output_path = root / doc_root / 'topology.md'

    # Walk + extract
    dirs = walk_top_level(root)
    edges = detect_dependencies(dirs, root)

    # Generate markdown
    content = generate_markdown(dirs, edges, output_path.parent.name)

    # Write
    output_path.parent.mkdir(parents=True, exist_ok=True)
    output_path.write_text(content, encoding='utf-8')

    print(f'Topology extracted: {output_path}', file=sys.stderr)
    print(f'  Components: {len(dirs)}', file=sys.stderr)
    print(f'  Dependencies: {len(edges)}', file=sys.stderr)


if __name__ == '__main__':
    main()
