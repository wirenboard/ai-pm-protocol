#!/usr/bin/env bash
# scripts/check-security-floor.sh
#
# Static security-capability detector (AP-16 hard floor для advisor'а).
#
# Раньше hard floor описывался только в discipline-advisor.md промпте — полагались
# на то что LLM не пропустит stripe/bcrypt/aes-gcm в зависимостях. Этот скрипт делает
# detection детерминированным: grep по манифестам и коду, output структурированный
# список detected capabilities → mandatory артефактов.
#
# Usage:
#   ./check-security-floor.sh                  — scan + JSON output на stdout
#   ./check-security-floor.sh --human          — human-readable output на stderr
#   ./check-security-floor.sh --enforce        — exit 1 если detected capabilities
#                                                не покрыты в spec/foundational docs
#   ./check-security-floor.sh --check <name>   — конкретный детектор (payments/auth/crypto/pii)
#
# Exit codes:
#   0 — clean (capabilities не detected или все покрыты)
#   1 — capabilities detected (с --enforce: missing coverage)
#   2 — script error (bad args / missing tools)
#
# Дизайн:
# - Конкретный catalog триггеров. Не AI-guess.
# - Multi-stack: package.json / pyproject.toml / requirements.txt / go.mod / Cargo.toml / Gemfile / composer.json
# - Lockfiles тоже сканируются (catch transitive deps)
# - Output потребляется advisor'ом + pre-commit hook'ом + bootstrap-agent'ом

set -e

MODE="json"
ENFORCE=0
SINGLE_CHECK=""

while [ $# -gt 0 ]; do
  case "$1" in
    --human)   MODE="human" ;;
    --enforce) ENFORCE=1 ;;
    --check)   shift; SINGLE_CHECK="$1" ;;
    -h|--help)
      sed -n '2,20p' "$0" >&2
      exit 0
      ;;
    *)
      echo "Unknown arg: $1" >&2
      exit 2
      ;;
  esac
  shift
done

# === Trigger catalog ===
#
# Format: PATTERN | CAPABILITY | EVIDENCE_TYPE
# EVIDENCE_TYPE — manifest | code | schema
#
# Каждая capability мапится на mandatory артефакты (см. MANDATORY_MAP ниже).

PAYMENTS_PATTERNS=(
  # JS/TS
  '"stripe"'
  '"@stripe/'
  '"paypal-rest-sdk"'
  '"@paypal/'
  '"square"'
  '"braintree"'
  # Python
  '^stripe[<=>~ ]'
  '^paypalrestsdk[<=>~ ]'
  '^braintree[<=>~ ]'
  # Go
  'github.com/stripe/stripe-go'
  'github.com/plutov/paypal'
  # Ruby
  "gem ['\"]stripe['\"]"
  "gem ['\"]braintree['\"]"
  # PHP
  '"stripe/stripe-php"'
  '"paypal/rest-api-sdk-php"'
)

AUTH_PATTERNS=(
  # JS/TS
  '"bcrypt"'
  '"bcryptjs"'
  '"argon2"'
  '"passport"'
  '"passport-'
  '"@auth0/'
  '"auth0"'
  '"jsonwebtoken"'
  '"next-auth"'
  '"@clerk/'
  '"firebase-admin"'
  '"@supabase/supabase-js"'
  # Python
  '^bcrypt[<=>~ ]'
  '^argon2[<=>~ ]'
  '^passlib[<=>~ ]'
  '^python-jose[<=>~ ]'
  '^pyjwt[<=>~ ]'
  '^authlib[<=>~ ]'
  '^django\.contrib\.auth'
  '^fastapi-users[<=>~ ]'
  # Go
  'golang.org/x/crypto/bcrypt'
  'github.com/golang-jwt/jwt'
  'github.com/dgrijalva/jwt-go'
  # Rust
  '^bcrypt = '
  '^argon2 = '
  '^jsonwebtoken = '
  # Ruby
  "gem ['\"]bcrypt['\"]"
  "gem ['\"]devise['\"]"
)

CRYPTO_PATTERNS_CODE=(
  # JS/TS — Node crypto module low-level usage
  'crypto\.createCipheriv'
  'crypto\.createDecipheriv'
  'crypto\.createHmac'
  'crypto\.scrypt'
  'crypto\.pbkdf2'
  # WebCrypto
  'AES-GCM'
  'AES-CBC'
  'subtle\.encrypt'
  'subtle\.decrypt'
  # Python
  'from cryptography'
  'from Crypto\.'
  'AES\.new'
  # Go
  'crypto/aes'
  'crypto/cipher'
  'golang.org/x/crypto/nacl'
  # Rust
  'use aes_gcm'
  'use chacha20'
  'use ring::aead'
  # Generic
  'libsodium'
  'sodium_'
)

CRYPTO_PATTERNS_MANIFEST=(
  '"libsodium-wrappers"'
  '"sodium-native"'
  '"node-forge"'
  '"crypto-js"'
  '^cryptography[<=>~ ]'
  '^pycryptodome[<=>~ ]'
  '^pynacl[<=>~ ]'
  'github.com/lestrrat-go/jwx'
  '^aes-gcm = '
  '^chacha20poly1305 = '
  '^ring = '
)

PII_PATTERNS_SCHEMA=(
  # Column names в schema/migration файлах
  'email[[:space:]]*[A-Z]*VARCHAR'
  'email[[:space:]]*[A-Z]*TEXT'
  'email[[:space:]]*String'
  'phone[[:space:]]*[A-Z]*VARCHAR'
  'phone_number[[:space:]]*'
  'date_of_birth'
  '\bdob\b'
  '\bssn\b'
  'social_security'
  'passport_number'
  'national_id'
  'tax_id'
  'credit_card'
)

# === Capability → mandatory artifacts ===

# Capability detection state (0/1)
HAS_PAYMENTS=0
HAS_AUTH=0
HAS_CRYPTO=0
HAS_PII=0

# Evidence accumulator
declare -A EVIDENCE
EVIDENCE[payments]=""
EVIDENCE[auth]=""
EVIDENCE[crypto]=""
EVIDENCE[pii]=""

# === Scan helpers ===

# Find manifest files в текущем repo (bounded — не идём в node_modules / vendor / venv).
find_manifests() {
  find . -type f \( \
    -name 'package.json' -o \
    -name 'package-lock.json' -o \
    -name 'pnpm-lock.yaml' -o \
    -name 'yarn.lock' -o \
    -name 'pyproject.toml' -o \
    -name 'requirements*.txt' -o \
    -name 'Pipfile' -o \
    -name 'Pipfile.lock' -o \
    -name 'poetry.lock' -o \
    -name 'go.mod' -o \
    -name 'go.sum' -o \
    -name 'Cargo.toml' -o \
    -name 'Cargo.lock' -o \
    -name 'Gemfile' -o \
    -name 'Gemfile.lock' -o \
    -name 'composer.json' -o \
    -name 'composer.lock' \
    \) \
    -not -path '*/node_modules/*' \
    -not -path '*/vendor/*' \
    -not -path '*/venv/*' \
    -not -path '*/.venv/*' \
    -not -path '*/dist/*' \
    -not -path '*/build/*' \
    -not -path '*/target/*' \
    2>/dev/null
}

find_code_files() {
  find . -type f \( \
    -name '*.ts' -o -name '*.tsx' -o \
    -name '*.js' -o -name '*.jsx' -o -name '*.mjs' -o \
    -name '*.py' -o \
    -name '*.go' -o \
    -name '*.rs' -o \
    -name '*.rb' -o \
    -name '*.php' \
    \) \
    -not -path '*/node_modules/*' \
    -not -path '*/vendor/*' \
    -not -path '*/venv/*' \
    -not -path '*/.venv/*' \
    -not -path '*/dist/*' \
    -not -path '*/build/*' \
    -not -path '*/target/*' \
    -not -path '*/test/*' \
    -not -path '*/tests/*' \
    -not -path '*/__tests__/*' \
    2>/dev/null
}

find_schema_files() {
  find . -type f \( \
    -name '*.sql' -o \
    -name 'schema.prisma' -o \
    -name '*.dbml' \
    \) \
    -not -path '*/node_modules/*' \
    -not -path '*/.venv/*' \
    2>/dev/null
  # Migration directories
  find . -type d \( -name 'migrations' -o -name 'migrate' -o -name 'db' \) \
    -not -path '*/node_modules/*' 2>/dev/null \
    | while read -r d; do find "$d" -type f \( -name '*.sql' -o -name '*.py' -o -name '*.rb' -o -name '*.js' \) 2>/dev/null; done
}

# Match patterns в file list. Append matched evidence к EVIDENCE[capability].
# Возвращает 0 (success) если ничего не найдено, 1 если найдено.
# Caller должен проверять EVIDENCE[capability] (не return code) — чище для bash.
scan_patterns() {
  local capability="$1"
  local files="$2"
  shift 2
  local patterns=("$@")
  for pattern in "${patterns[@]}"; do
    while IFS= read -r match_file; do
      [ -z "$match_file" ] && continue
      EVIDENCE[$capability]+="${match_file}:${pattern}\n"
    done < <(echo "$files" | xargs -r grep -lE "$pattern" 2>/dev/null | head -3)
  done
}

# === Run detectors ===

run_payments() {
  local manifests
  manifests=$(find_manifests)
  [ -z "$manifests" ] && return 0
  scan_patterns "payments" "$manifests" "${PAYMENTS_PATTERNS[@]}"
  if [ -n "${EVIDENCE[payments]}" ]; then HAS_PAYMENTS=1; fi
  return 0
}

run_auth() {
  local manifests
  manifests=$(find_manifests)
  [ -z "$manifests" ] && return 0
  scan_patterns "auth" "$manifests" "${AUTH_PATTERNS[@]}"
  if [ -n "${EVIDENCE[auth]}" ]; then HAS_AUTH=1; fi
  return 0
}

run_crypto() {
  local manifests code
  manifests=$(find_manifests)
  code=$(find_code_files)
  if [ -n "$manifests" ]; then
    scan_patterns "crypto" "$manifests" "${CRYPTO_PATTERNS_MANIFEST[@]}"
  fi
  if [ -n "$code" ]; then
    scan_patterns "crypto" "$code" "${CRYPTO_PATTERNS_CODE[@]}"
  fi
  if [ -n "${EVIDENCE[crypto]}" ]; then HAS_CRYPTO=1; fi
  return 0
}

run_pii() {
  local schemas
  schemas=$(find_schema_files)
  [ -z "$schemas" ] && return 0
  scan_patterns "pii" "$schemas" "${PII_PATTERNS_SCHEMA[@]}"
  if [ -n "${EVIDENCE[pii]}" ]; then HAS_PII=1; fi
  return 0
}

# === Map capability → mandatory artifacts ===

mandatory_for() {
  local cap="$1"
  case "$cap" in
    payments) echo "threat-model.md legal.md" ;;
    auth)     echo "threat-model.md" ;;
    crypto)   echo "threat-model.md" ;;
    pii)      echo "threat-model.md legal.md database-design-base.md" ;;
  esac
}

# === Output ===

emit_json() {
  echo "{"
  echo "  \"detected\": {"
  echo "    \"payments\": $([ $HAS_PAYMENTS -eq 1 ] && echo true || echo false),"
  echo "    \"auth\":     $([ $HAS_AUTH -eq 1 ] && echo true || echo false),"
  echo "    \"crypto\":   $([ $HAS_CRYPTO -eq 1 ] && echo true || echo false),"
  echo "    \"pii\":      $([ $HAS_PII -eq 1 ] && echo true || echo false)"
  echo "  },"
  echo "  \"mandatory\": ["
  local first=1
  for cap in payments auth crypto pii; do
    local flag_var="HAS_${cap^^}"
    if [ "${!flag_var}" -eq 1 ]; then
      for art in $(mandatory_for "$cap"); do
        [ $first -eq 0 ] && echo ","
        printf '    {"artifact": "%s", "reason": "%s capability detected"}' "$art" "$cap"
        first=0
      done
    fi
  done
  echo ""
  echo "  ],"
  echo "  \"evidence\": {"
  first=1
  for cap in payments auth crypto pii; do
    local flag_var="HAS_${cap^^}"
    if [ "${!flag_var}" -eq 1 ]; then
      [ $first -eq 0 ] && echo ","
      printf '    "%s": [' "$cap"
      local ev_first=1
      while IFS= read -r line; do
        [ -z "$line" ] && continue
        # JSON-escape: backslash → \\, quote → \"
        local escaped="${line//\\/\\\\}"
        escaped="${escaped//\"/\\\"}"
        [ $ev_first -eq 0 ] && printf ","
        printf '"%s"' "$escaped"
        ev_first=0
      done <<< "$(printf '%b' "${EVIDENCE[$cap]}" | sort -u | head -5)"
      printf ']'
      first=0
    fi
  done
  echo ""
  echo "  }"
  echo "}"
}

emit_human() {
  echo "=== Security-capability detection ===" >&2
  local total=0
  for cap in payments auth crypto pii; do
    local flag_var="HAS_${cap^^}"
    if [ "${!flag_var}" -eq 1 ]; then
      total=$((total + 1))
      echo "" >&2
      echo "[$cap] DETECTED" >&2
      echo "  mandatory: $(mandatory_for $cap)" >&2
      echo "  evidence (first 3):" >&2
      printf '%b' "${EVIDENCE[$cap]}" | sort -u | head -3 | sed 's/^/    /' >&2
    fi
  done
  if [ $total -eq 0 ]; then
    echo "Чисто — security-чувствительных capability'ей не обнаружено." >&2
  else
    echo "" >&2
    echo "Skip недоступен для перечисленных артефактов (AP-16 hard floor)." >&2
  fi
}

# === Enforcement ===
# Check что mandatory артефакты actually exist в репе.

enforce_coverage() {
  local missing=""
  local doc_root="doc"
  [ -d ".ai-pm/doc" ] && doc_root=".ai-pm/doc"
  for cap in payments auth crypto pii; do
    local flag_var="HAS_${cap^^}"
    if [ "${!flag_var}" -eq 1 ]; then
      for art in $(mandatory_for "$cap"); do
        if [ ! -f "$doc_root/$art" ] && [ ! -f "doc/$art" ] && [ ! -f ".ai-pm/doc/$art" ]; then
          missing+="\n  $art (required by $cap)"
        fi
      done
    fi
  done
  if [ -n "$missing" ]; then
    echo "" >&2
    echo "BLOCKED: security floor нарушен (AP-16 hard rule)." >&2
    printf 'Missing mandatory артефакты:%b\n' "$missing" >&2
    echo "" >&2
    echo "Опции:" >&2
    echo "  (а) Создать missing артефакты (рекомендуется)" >&2
    echo "  (б) AP-22 adoption-override в .ai-pm/.bootstrap-state.md (declared trade-off с accepted-risk)" >&2
    return 1
  fi
  return 0
}

# === Main ===

case "$SINGLE_CHECK" in
  payments) run_payments ;;
  auth)     run_auth ;;
  crypto)   run_crypto ;;
  pii)      run_pii ;;
  "")
    run_payments
    run_auth
    run_crypto
    run_pii
    ;;
  *)
    echo "Unknown check: $SINGLE_CHECK (известные: payments / auth / crypto / pii)" >&2
    exit 2
    ;;
esac

case "$MODE" in
  json)  emit_json ;;
  human) emit_human ;;
esac

# Determine total capabilities detected
TOTAL=$((HAS_PAYMENTS + HAS_AUTH + HAS_CRYPTO + HAS_PII))

if [ $ENFORCE -eq 1 ]; then
  # --enforce: exit отражает coverage status (0 = all covered or nothing detected)
  if [ $TOTAL -eq 0 ]; then
    exit 0
  fi
  enforce_coverage && exit 0 || exit 1
fi

# default: exit 1 если capabilities detected (informational signal для caller)
[ $TOTAL -gt 0 ] && exit 1
exit 0
