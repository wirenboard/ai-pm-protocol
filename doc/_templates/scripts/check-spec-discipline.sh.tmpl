#!/usr/bin/env bash
# scripts/check-spec-discipline.sh
# Реализует Spec/use-case linting catalogue из development-protocol.md § 9.
#
# Usage:
#   ./check-spec-discipline.sh                  — полный pass по всем checks
#   ./check-spec-discipline.sh --staged-only    — только staged файлы (для pre-commit)
#   ./check-spec-discipline.sh --check <name>   — конкретный check
#
# Exit codes:
#   0 — all checks passed
#   1 — at least one check failed
#   2 — invocation error

set -e

# DOC_ROOT — читается из .ai-pm/.bootstrap-state.md frontmatter поле `doc_root:`.
# Default для new projects: doc (top-level).
# Для retrofit projects с existing doc/: .ai-pm/doc.
DOC_ROOT=$(awk -F': ' '/^doc_root:/ {print $2; exit}' .ai-pm/.bootstrap-state.md 2>/dev/null | tr -d ' ')
DOC_ROOT="${DOC_ROOT:-doc}"

# FOUNDATION_COMPLETENESS — читается из state file. Determines check behavior
# для AP-14 / AP-15 / mini-* sections. См. design doc § F-I.
# Values: complete | partial | minimal | none. Default: complete (backwards compat).
FOUNDATION_COMPLETENESS=$(awk -F': ' '/^foundation_completeness:/ {print $2; exit}' .ai-pm/.bootstrap-state.md 2>/dev/null | tr -d ' ')
FOUNDATION_COMPLETENESS="${FOUNDATION_COMPLETENESS:-complete}"

# ADOPTION_OVERRIDES — список skip entries из state file (для downgrade affected checks).
# Parsed best-effort через grep.
ADOPTION_OVERRIDES_SKIP=$(awk '/^adoption_overrides:/,/^[a-z_]+:/ {if (/^\s*- skip:/) print $3}' .ai-pm/.bootstrap-state.md 2>/dev/null | tr -d '"' | tr -d "'")

FAILED=0
WARNINGS=0

log_fail() {
  echo "FAIL: $1" >&2
  FAILED=$((FAILED + 1))
}

log_warn() {
  echo "WARN: $1" >&2
  WARNINGS=$((WARNINGS + 1))
}

log_ok() {
  echo "OK: $1"
}

# log_downgraded — used когда finding affected by adoption_override
# Treats как warn, не fail. Surface override tag в message.
log_downgraded() {
  local check="$1"
  local override="$2"
  echo "WARN (adoption-trade-off accepted by operator: $override): $check" >&2
  WARNINGS=$((WARNINGS + 1))
}

# is_overridden — check если component в adoption_overrides skip list
is_overridden() {
  local component="$1"
  echo "$ADOPTION_OVERRIDES_SKIP" | grep -qE "^${component}$"
}

# === Check 1: personas-exist ===
# State-aware: при foundation_completeness != complete — missing personas.md OK
# если spec'и используют Mini-persona sections (Tier 1).
check_personas_exist() {
  local f="$DOC_ROOT/personas.md"
  if [ ! -f "$f" ]; then
    if [ "$FOUNDATION_COMPLETENESS" = "complete" ]; then
      log_fail "personas-exist: $f не существует (foundation_completeness=complete required)"
    elif is_overridden "personas"; then
      log_downgraded "personas-exist: $f не существует" "personas"
    else
      log_warn "personas-exist: $f не существует (foundation_completeness=$FOUNDATION_COMPLETENESS — using Tier 1 mini-personas в spec'ах)"
    fi
    return
  fi
  # Проверка что не placeholder (нет `<…>` маркеров на > 50% строк)
  local total=$(wc -l < "$f")
  local placeholders=$(grep -c '<.*>' "$f" || true)
  if [ "$total" -gt 0 ] && [ "$placeholders" -gt $((total / 2)) ]; then
    log_fail "personas-exist: $f выглядит как placeholder (много <…> маркеров)"
    return
  fi
  # Проверка наличия хотя бы одной persona (heuristic: header '## Persona')
  if ! grep -q '^## Persona' "$f"; then
    log_fail "personas-exist: $f не содержит ни одного '## Persona' header'а"
    return
  fi
  log_ok "personas-exist"
}

# === Check 2: journeys-reference-personas ===
check_journeys_reference_personas() {
  local p="$DOC_ROOT/personas.md"
  local j="$DOC_ROOT/user-journeys.md"
  if [ ! -f "$j" ]; then
    log_fail "journeys-reference-personas: $j не существует"
    return
  fi
  # Extract persona names (heuristic: '## Persona X:' → X)
  local personas=$(grep -oE '^## Persona [A-Z0-9]+' "$p" 2>/dev/null | awk '{print $3}' | tr -d ':' || true)
  if [ -z "$personas" ]; then
    log_warn "journeys-reference-personas: не удалось извлечь personas из $p (skip)"
    return
  fi
  # Каждая persona должна упоминаться в journeys
  for persona in $personas; do
    if ! grep -q "Persona $persona" "$j"; then
      log_fail "journeys-reference-personas: Persona $persona в $p, но не упомянута в $j"
    fi
  done
  log_ok "journeys-reference-personas"
}

# === Check 3: mvp-scope-no-orphans ===
check_mvp_scope_no_orphans() {
  local scope="$DOC_ROOT/mvp-scope.md"
  if [ ! -f "$scope" ]; then
    log_warn "mvp-scope-no-orphans: $scope не существует (Stage B incomplete)"
    return
  fi
  # Heuristic: F-IDs в формате `**F01:`, `**F02:` etc.
  local fids=$(grep -oE '\*\*F[0-9]+:' "$scope" | tr -d '*:' || true)
  for fid in $fids; do
    # Ищем matching spec (любой файл, начинающийся на feature topic с F-ID)
    if ! ls "$DOC_ROOT/features/"*"_spec.md" 2>/dev/null | xargs grep -l "$fid" >/dev/null 2>&1; then
      # Может быть deferred
      if grep -A1 "$fid:" "$scope" | grep -qi "deferred"; then
        continue
      fi
      log_warn "mvp-scope-no-orphans: $fid в $scope, но spec не найден и не помечен deferred"
    fi
  done
  log_ok "mvp-scope-no-orphans"
}

# === Check 4: foundational-docs-filled ===
# State-aware: при foundation_completeness != complete — missing docs ожидаемы.
# При complete — все 4 должны быть filled.
check_foundational_docs_filled() {
  local docs=("personas.md" "user-journeys.md" "threat-model.md" "mvp-scope.md")
  for doc in "${docs[@]}"; do
    local f="$DOC_ROOT/$doc"
    local component_name="${doc%.md}"
    if [ ! -f "$f" ]; then
      if [ "$FOUNDATION_COMPLETENESS" = "complete" ]; then
        log_fail "foundational-docs-filled: $f отсутствует"
      elif is_overridden "$component_name"; then
        log_downgraded "foundational-docs-filled: $f отсутствует" "$component_name"
      else
        log_warn "foundational-docs-filled: $f отсутствует (foundation_completeness=$FOUNDATION_COMPLETENESS — using Tier 1 mini-sections)"
      fi
      continue
    fi
    local total=$(wc -l < "$f")
    local placeholders=$(grep -c '<.*>' "$f" || echo 0)
    if [ "$total" -gt 10 ] && [ "$placeholders" -gt $((total / 3)) ]; then
      log_fail "foundational-docs-filled: $f содержит много placeholder'ов <…> ($placeholders/$total строк)"
    fi
  done
  log_ok "foundational-docs-filled"
}

# === Check 5: spec-structure ===
check_spec_structure() {
  local required=("## Контекст" "## User stories" "## Сценарии" "## Non-functional" "## Не в scope" "## Open questions")
  for spec in "$DOC_ROOT/features/"*_spec.md; do
    [ -e "$spec" ] || continue
    for section in "${required[@]}"; do
      if ! grep -qF "$section" "$spec"; then
        log_fail "spec-structure: $spec missing section '$section'"
      fi
    done
  done
  log_ok "spec-structure"
}

# === Check 6: plan-exists-for-spec ===
check_plan_exists_for_spec() {
  for spec in "$DOC_ROOT/features/"*_spec.md; do
    [ -e "$spec" ] || continue
    local topic=$(basename "$spec" _spec.md)
    local plan="$DOC_ROOT/features/${topic}_plan.md"
    if [ ! -f "$plan" ]; then
      # OK если spec ещё не approved (нет operator-marker)
      if grep -qE "(approved|ок|поехали)" "$spec"; then
        log_fail "plan-exists-for-spec: $spec помечен approved, но $plan отсутствует"
      fi
    fi
  done
  log_ok "plan-exists-for-spec"
}

# === Check 7: rework-has-diff-section / migration-section ===
check_rework_sections() {
  for spec in "$DOC_ROOT/features/"*_spec.v*.md; do
    [ -e "$spec" ] || continue
    if ! grep -qF "## Diff" "$spec"; then
      log_fail "rework-has-diff-section: $spec не содержит '## Diff' section"
    fi
  done
  for plan in "$DOC_ROOT/features/"*_plan.v*.md; do
    [ -e "$plan" ] || continue
    if ! grep -qF "## Migration" "$plan"; then
      log_fail "rework-has-migration-section: $plan не содержит '## Migration' section"
    fi
  done
  log_ok "rework-sections"
}

# === Check 8: spec-references-persona ===
# State-aware: при foundation_completeness != complete — spec может использовать
# Mini-persona section inline вместо project-wide persona reference. OK тоже.
check_spec_references_persona() {
  local personas=$(grep -oE '^## Persona [A-Z0-9]+' "$DOC_ROOT/personas.md" 2>/dev/null | awk '{print $3}' | tr -d ':' || true)
  for spec in "$DOC_ROOT/features/"*_spec.md; do
    [ -e "$spec" ] || continue
    local found=0
    # Check 1: references к project-wide personas
    if [ -n "$personas" ]; then
      for persona in $personas; do
        if grep -q "Persona $persona\|persona $persona" "$spec"; then
          found=1
          break
        fi
      done
    fi
    # Check 2: inline Mini-persona section (Tier 1)
    if [ "$found" -eq 0 ] && grep -qF "## Mini-persona" "$spec"; then
      found=1
    fi
    if [ "$found" -eq 0 ]; then
      log_fail "spec-references-persona: $spec не ссылается ни на одну persona и не содержит Mini-persona section"
    fi
  done
  log_ok "spec-references-persona"
}

# === Check 9: spec-impact-fields-present (AP-14 enforcement) ===
# Каждый _spec.md обязан содержать 7 impact полей в frontmatter:
# 3 operational (AP-13): legal_impact, validation_required, incident_impact
# 4 structural (AP-14): journey_impact, threat_impact, scope_impact, topology_impact
# Каждое поле должно иметь значение `yes` или `no` — не пусто, не отсутствовать.
# Это enforce'ит обязательный structural read-pass перед draft'ом spec'а.
check_spec_impact_fields() {
  local required_fields=(
    "legal_impact"
    "validation_required"
    "incident_impact"
    "journey_impact"
    "threat_impact"
    "scope_impact"
    "topology_impact"
  )
  for spec in "$DOC_ROOT/features/"*_spec.md; do
    [ -e "$spec" ] || continue
    # Skip lite-mode: bugfix — для bugfix импакты обычно тривиальны (см. AP-13/14 exceptions)
    if grep -qE '^lite-mode:[[:space:]]*bugfix' "$spec"; then
      continue
    fi
    # Extract frontmatter block (от первого `---` до второго)
    local frontmatter
    frontmatter=$(awk '/^---$/{c++; next} c==1' "$spec" 2>/dev/null)
    if [ -z "$frontmatter" ]; then
      log_fail "spec-impact-fields-present: $spec не содержит frontmatter блока"
      continue
    fi
    for field in "${required_fields[@]}"; do
      # Поле должно присутствовать с явным yes|no значением
      if ! echo "$frontmatter" | grep -qE "^${field}:[[:space:]]+(yes|no)([[:space:]]|$)"; then
        log_fail "spec-impact-fields-present: $spec — поле '${field}' отсутствует или не yes/no (AP-14 read-pass пропущен)"
      fi
    done
  done
  log_ok "spec-impact-fields-present"
}

# === Check 10: pr-ordering-for-multi-domain (AP-19 enforcement) ===
# Если spec scenarios или Контекст касаются ≥ 2 domains (schema/db + API/backend + UI/frontend),
# frontmatter обязан содержать `pr_ordering: [...]` с явным списком.
# Это enforce'ит AP-19 per-PR atomicity на Step 2 (plan), не на Step 4 (coder эскалирует поздно).
check_pr_ordering_for_multi_domain() {
  for spec in "$DOC_ROOT/features/"*_spec.md; do
    [ -e "$spec" ] || continue
    # Skip lite-mode: bugfix / small-fix — обычно single-domain
    if grep -qE '^lite-mode:[[:space:]]*(bugfix|small-fix)' "$spec"; then
      continue
    fi
    # Extract domain hints из spec body (после frontmatter — два `---`)
    local body
    body=$(awk '/^---$/{c++; next} c>=2' "$spec" 2>/dev/null)
    # Detect domains: regex против обычных indicator'ов
    local domains=0
    if echo "$body" | grep -qiE '\b(schema|migration|database|таблиц|колонк|индекс|sql)'; then
      domains=$((domains + 1))
    fi
    if echo "$body" | grep -qiE '\b(API|endpoint|route|REST|GraphQL|webhook|RPC|контракт)'; then
      domains=$((domains + 1))
    fi
    if echo "$body" | grep -qiE '\b(UI|page|view|form|component|компонент|страниц|форм)'; then
      domains=$((domains + 1))
    fi
    # Multi-domain detected → pr_ordering обязателен
    if [ "$domains" -ge 2 ]; then
      local frontmatter
      frontmatter=$(awk '/^---$/{c++; next} c==1' "$spec" 2>/dev/null)
      # Frontmatter has pr_ordering: [<list>] (не null, не пусто)
      if ! echo "$frontmatter" | grep -qE '^pr_ordering:[[:space:]]*\['; then
        log_fail "pr-ordering-for-multi-domain: $spec touches ${domains} domains, но frontmatter не содержит 'pr_ordering: [...]' (AP-19)"
      fi
    fi
  done
  log_ok "pr-ordering-for-multi-domain"
}

# === Check 12: test-assertion-weakening (AP-23 enforcement) ===
# Detect модифицированные test-файлы в HEAD-commit (или staged set) и требует
# в commit message ADR-NNNN reference ИЛИ explicit `[test-modify-override: <reason>]`
# marker. Pure additions (новые test-файлы) — пропускаются, триггерят только modifications.
#
# Failure mode что закрывается: agent ослабляет existing assertion (`toBe(100)` →
# `toBeGreaterThan(50)`), удаляет проверку, или mock'ает наружу — test runner
# зелёный, но behaviour поменялся молча. Гейт заставляет declared trade-off
# через ADR (см. AP-23, paradigm-compatible с AP-22).
#
# Mode: requires-ADR — не hard block. Operator override через ADR или marker.
check_test_assertion_weakening() {
  # Diff scope: при --staged-only — index vs HEAD; иначе HEAD vs HEAD~1.
  local diff_args
  if [ "${STAGED_ONLY:-0}" = "1" ]; then
    diff_args="--cached"
  else
    # Если HEAD~1 нет (первый commit) — нечего проверять
    if ! git rev-parse HEAD~1 >/dev/null 2>&1; then
      log_ok "test-assertion-weakening (no prior commit, skip)"
      return
    fi
    diff_args="HEAD~1 HEAD"
  fi

  # Modified-only (--diff-filter=M); added (A) и renamed (R) — не триггерят.
  local modified_tests
  modified_tests=$(git diff --diff-filter=M --name-only $diff_args 2>/dev/null | grep -E '(_test\.(go|py)|test_.+\.py|.+\.(test|spec)\.(js|jsx|ts|tsx|mjs|cjs)|_spec\.rb|Test\.(java|kt)|Tests\.cs|\.feature)$' || true)

  if [ -z "$modified_tests" ]; then
    log_ok "test-assertion-weakening (no modified test files)"
    return
  fi

  # Получаем commit message (HEAD или, для staged режима — COMMIT_EDITMSG если pre-commit, иначе HEAD)
  local commit_msg
  if [ "${STAGED_ONLY:-0}" = "1" ] && [ -f ".git/COMMIT_EDITMSG" ]; then
    commit_msg=$(cat .git/COMMIT_EDITMSG 2>/dev/null)
  else
    commit_msg=$(git log -1 --format=%B 2>/dev/null)
  fi

  # Check для ADR ref (формат ADR-NNNN — 4 digits) OR override marker
  local has_adr_ref=0
  local has_override=0
  if echo "$commit_msg" | grep -qE 'ADR-[0-9]{4}'; then
    has_adr_ref=1
  fi
  if echo "$commit_msg" | grep -qE '\[test-modify-override:[[:space:]]*[^]]+\]'; then
    has_override=1
  fi

  if [ "$has_adr_ref" -eq 0 ] && [ "$has_override" -eq 0 ]; then
    log_fail "test-assertion-weakening: modified test file(s) require ADR-NNNN reference OR [test-modify-override: <reason>] marker в commit message per AP-23"
    echo "  Modified test files:" >&2
    echo "$modified_tests" | sed 's/^/    - /' >&2
    echo "  Recommended commit body line:" >&2
    echo "    Modifies test: see ADR-NNNN — reason: <behaviour changed because Z>" >&2
    echo "  OR explicit override:" >&2
    echo "    [test-modify-override: <reason>]" >&2
    return
  fi

  log_ok "test-assertion-weakening (declared trade-off present)"
}

# === Check 11: security-spec-cites-standard (conditional) ===
check_security_spec_cites_standard() {
  for spec in "$DOC_ROOT/features/"*_spec.md; do
    [ -e "$spec" ] || continue
    # Heuristic: spec считается security-touching, если в нём упоминается auth/crypto/PII/payments/session
    if grep -qiE 'auth|crypto|PII|payment|session|secret' "$spec"; then
      # Должна быть Security invariants секция с OWASP/CWE/ASVS ссылками
      if ! grep -qF "## Security invariants" "$spec"; then
        log_warn "security-spec-cites-standard: $spec выглядит security-touching, но без '## Security invariants' секции"
        continue
      fi
      if ! grep -qiE 'OWASP|CWE|ASVS' "$spec"; then
        log_fail "security-spec-cites-standard: $spec упоминает security-touching, но не ссылается на OWASP/CWE/ASVS стандарты в Security invariants"
      fi
    fi
  done
  log_ok "security-spec-cites-standard"
}

# === Gap 1 (v0.2.0): spec→test mapping — каждый Gherkin Scenario имеет matching test ===
#
# Парсит Gherkin `Scenario:` lines из feature spec'ов и ищет matching test name
# в test directories. Multi-stack heuristic: ищет scenario name (case-insensitive,
# normalized whitespace) в test files как substring (covers `describe('Scenario: ...')`,
# `def test_scenario_*`, `func TestScenario*`, `@pytest.mark.scenario`, BDD framework
# patterns и др.).
#
# Per-stack mapping convention'ы могут быть закреплены в `ai-linting-rules.md`
# (Stage E генерирует под выбранный стек). Этот check работает best-effort при
# отсутствии конвенции — если test не находится — fail.
#
# Skip patterns:
# - `lite-mode: bugfix` — bugfix specs могут не иметь Gherkin (regression tests
#   через failing-test-first AP-5)
# - Spec без Gherkin блоков — silent skip (не security-touching spec'и часто нет
#   Gherkin'а, только NFR)
check_spec_test_mapping() {
  local found_specs=0
  local missing_count=0

  for spec in "$DOC_ROOT/features/"*_spec.md "$DOC_ROOT/features/"*_spec.v*.md; do
    [ -e "$spec" ] || continue
    found_specs=$((found_specs + 1))

    # Skip bugfix lite-mode (regression test policy через AP-5)
    if grep -qE '^lite-mode:\s*bugfix' "$spec" 2>/dev/null; then
      continue
    fi

    # Extract scenario names — Gherkin lines starting с `Scenario:` или `Scenario Outline:`
    # Normalize: trim, single-space, lowercase для loose match
    local scenarios
    scenarios=$(grep -E '^\s*Scenario(\s+Outline)?:' "$spec" 2>/dev/null | \
                sed -E 's/^\s*Scenario(\s+Outline)?:\s*//' | \
                sed -E 's/[[:space:]]+/ /g' | \
                sed 's/^ //;s/ $//' || true)

    [ -z "$scenarios" ] && continue

    while IFS= read -r scenario_name; do
      [ -z "$scenario_name" ] && continue

      # Search test directories для matching scenario name (case-insensitive substring)
      # Common test paths multi-stack: test/ tests/ __tests__/ spec/ e2e/ + *_test.* / test_*.*
      local found=""
      # shellcheck disable=SC2086
      found=$(find . \( -type d \( -name node_modules -o -name .git -o -name target -o -name dist -o -name build -o -name venv -o -name .venv \) -prune \) -o \
              -type f \( -name '*_test.go' -o -name '*_test.py' -o -name 'test_*.py' -o \
                         -name '*.test.js' -o -name '*.test.jsx' -o -name '*.test.ts' -o -name '*.test.tsx' -o \
                         -name '*.spec.js' -o -name '*.spec.jsx' -o -name '*.spec.ts' -o -name '*.spec.tsx' -o \
                         -name '*_spec.rb' -o -name '*Test.java' -o -name '*Test.kt' -o -name '*Tests.cs' -o \
                         -name '*.feature' \) -print 2>/dev/null | \
              xargs -I{} grep -lFi "$scenario_name" {} 2>/dev/null | head -1 || true)

      if [ -z "$found" ]; then
        log_fail "spec-test-mapping: '$scenario_name' (из $spec) — нет matching test"
        missing_count=$((missing_count + 1))
      fi
    done <<< "$scenarios"
  done

  if [ "$found_specs" -eq 0 ]; then
    log_ok "spec-test-mapping (no specs to check)"
    return
  fi

  if [ "$missing_count" -eq 0 ]; then
    log_ok "spec-test-mapping"
  fi
}

# === Gap 3 (v0.2.0): regression-coverage-for-shared-modules ===
# AP-14 extension: spec с topology_impact: yes обязан содержать секцию
# `## Regression coverage plan`. Detect через frontmatter + body grep.
# Skip: lite-mode:bugfix, явная пометка `N/A — standalone`.
check_regression_coverage_for_shared_modules() {
  local missing_count=0
  for spec in "$DOC_ROOT/features/"*_spec.md "$DOC_ROOT/features/"*_spec.v*.md; do
    [ -e "$spec" ] || continue

    # Skip lite-mode:bugfix
    if grep -qE '^lite-mode:\s*bugfix' "$spec" 2>/dev/null; then
      continue
    fi

    # Trigger condition: topology_impact: yes в frontmatter (первые 30 lines)
    if ! head -30 "$spec" | grep -qE '^topology_impact:\s*yes' 2>/dev/null; then
      continue
    fi

    # Require секция `## Regression coverage plan`
    if ! grep -qF '## Regression coverage plan' "$spec"; then
      log_fail "regression-coverage-for-shared-modules: $spec — topology_impact:yes, но нет секции '## Regression coverage plan' (AP-14 extension)"
      missing_count=$((missing_count + 1))
    fi
  done

  if [ "$missing_count" -eq 0 ]; then
    log_ok "regression-coverage-for-shared-modules"
  fi
}

# === AP-24 (v0.2.0): adr-auto-extraction ===
# Detect spec sections с keywords `инвариант`, `архитектура`, `trade-off`, `decision`,
# измеряет LOC между `## <heading>` и следующим `## `:
# - > 30 LOC arch content → warn (suggest ADR extraction)
# - > 50 LOC arch content без ADR ref в spec'е → fail (AP-24)
# Skip: lite-mode:bugfix.
check_adr_auto_extraction() {
  local fail_count=0
  for spec in "$DOC_ROOT/features/"*_spec.md "$DOC_ROOT/features/"*_spec.v*.md; do
    [ -e "$spec" ] || continue

    # Skip bugfix
    if grep -qE '^lite-mode:\s*bugfix' "$spec" 2>/dev/null; then
      continue
    fi

    # Check: spec содержит ADR reference?
    local has_adr_ref="no"
    if grep -qE '(ADR-[0-9]+|architecture-decisions/[0-9])' "$spec" 2>/dev/null; then
      has_adr_ref="yes"
    fi

    # Parse: для каждого `## <heading>` посчитать LOC до следующего `## ` или EOF
    # Если heading имеет architectural keyword — проверить порог
    awk -v spec="$spec" -v has_ref="$has_adr_ref" '
      /^## / {
        if (curr_section != "" && is_arch) {
          if (loc > 50 && has_ref == "no") {
            printf "ARCH_FAIL\t%s\t%s\t%d\n", spec, curr_section, loc
          } else if (loc > 30) {
            printf "ARCH_WARN\t%s\t%s\t%d\n", spec, curr_section, loc
          }
        }
        curr_section = $0
        is_arch = (tolower($0) ~ /инвариант|архитектура|trade.?off|decision|architectur/)
        loc = 0
        next
      }
      { loc++ }
      END {
        if (curr_section != "" && is_arch) {
          if (loc > 50 && has_ref == "no") {
            printf "ARCH_FAIL\t%s\t%s\t%d\n", spec, curr_section, loc
          } else if (loc > 30) {
            printf "ARCH_WARN\t%s\t%s\t%d\n", spec, curr_section, loc
          }
        }
      }
    ' "$spec" | while IFS=$'\t' read -r kind file section_hdr arch_loc; do
      if [ "$kind" = "ARCH_FAIL" ]; then
        log_fail "adr-auto-extraction: $file — '$section_hdr' содержит ${arch_loc} LOC architectural content без ADR ref (AP-24, extract в architecture-decisions/)"
        fail_count=$((fail_count + 1))
      else
        log_warn "adr-auto-extraction: $file — '$section_hdr' содержит ${arch_loc} LOC architectural content (suggest ADR extraction per AP-24)"
      fi
    done
  done

  if [ "$fail_count" -eq 0 ]; then
    log_ok "adr-auto-extraction"
  fi
}

# === Main ===
case "${1:-all}" in
  --staged-only)
    # Pre-commit hook режим — checks, которые имеют смысл на staged set.
    # На v0 запускаем те, которые работают на repo state без heavy file scans.
    export STAGED_ONLY=1
    check_test_assertion_weakening
    ;;
  --check)
    shift
    if [ -z "${1:-}" ]; then
      echo "Usage: $0 --check <check-name>" >&2
      exit 2
    fi
    "check_${1//-/_}"
    ;;
  all|*)
    check_personas_exist
    check_journeys_reference_personas
    check_mvp_scope_no_orphans
    check_foundational_docs_filled
    check_spec_structure
    check_plan_exists_for_spec
    check_rework_sections
    check_spec_references_persona
    check_spec_impact_fields
    check_pr_ordering_for_multi_domain
    check_security_spec_cites_standard
    check_spec_test_mapping
    check_test_assertion_weakening
    check_regression_coverage_for_shared_modules
    check_adr_auto_extraction
    ;;
esac

echo ""
echo "Summary: $FAILED FAILED, $WARNINGS WARNINGS"

if [ "$FAILED" -gt 0 ]; then
  exit 1
fi
exit 0
