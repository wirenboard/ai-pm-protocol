#!/usr/bin/env bash
# .ai-pm/tooling/scripts/check-spec-discipline.sh
# –†–µ–∞–ї–Є–Ј—Г–µ—В Spec/use-case linting catalogue –Є–Ј development-protocol.md ¬І 9.
#
# Usage:
#   ./check-spec-discipline.sh                  вАФ –њ–Њ–ї–љ—Л–є pass –њ–Њ –≤—Б–µ–Љ checks
#   ./check-spec-discipline.sh --staged-only    вАФ —В–Њ–ї—М–Ї–Њ staged —Д–∞–є–ї—Л (–і–ї—П pre-commit)
#   ./check-spec-discipline.sh --check <name>   вАФ –Ї–Њ–љ–Ї—А–µ—В–љ—Л–є check
#
# Exit codes:
#   0 вАФ all checks passed
#   1 вАФ at least one check failed
#   2 вАФ invocation error

set -e

# DOC_ROOT вАФ —З–Є—В–∞–µ—В—Б—П –Є–Ј .ai-pm/.bootstrap-state.md frontmatter –њ–Њ–ї–µ `doc_root:`.
# Default –і–ї—П new projects: doc (top-level).
# –Ф–ї—П retrofit projects —Б existing doc/: .ai-pm/doc.
DOC_ROOT=$(awk -F': ' '/^doc_root:/ {print $2; exit}' .ai-pm/.bootstrap-state.md 2>/dev/null | tr -d ' ')
DOC_ROOT="${DOC_ROOT:-doc}"

# FOUNDATION_COMPLETENESS вАФ —З–Є—В–∞–µ—В—Б—П –Є–Ј state file. Determines check behavior
# –і–ї—П AP-14 / AP-15 / mini-* sections. –°–Љ. design doc ¬І F-I.
# Values: complete | partial | minimal | none. Default: complete (backwards compat).
FOUNDATION_COMPLETENESS=$(awk -F': ' '/^foundation_completeness:/ {print $2; exit}' .ai-pm/.bootstrap-state.md 2>/dev/null | tr -d ' ')
FOUNDATION_COMPLETENESS="${FOUNDATION_COMPLETENESS:-complete}"

# ADOPTION_OVERRIDES вАФ —Б–њ–Є—Б–Њ–Ї skip entries –Є–Ј state file (–і–ї—П downgrade affected checks).
# Parsed best-effort —З–µ—А–µ–Ј grep.
ADOPTION_OVERRIDES_SKIP=$(awk '/^adoption_overrides:/,/^[a-z_]+:/ {if (/^\s*- skip:/) print $3}' .ai-pm/.bootstrap-state.md 2>/dev/null | tr -d '"' | tr -d "'")

FAILED=0
WARNINGS=0

log_fail() {
  echo "FAIL: $1" >&2
  FAILED=$((FAILED + 1))
}

log_warn() {
  echo "WARN: $1" >&2
  WARNINGS=$((WARNINGS + 1))
}

log_ok() {
  echo "OK: $1"
}

# log_downgraded вАФ used –Ї–Њ–≥–і–∞ finding affected by adoption_override
# Treats –Ї–∞–Ї warn, –љ–µ fail. Surface override tag –≤ message.
log_downgraded() {
  local check="$1"
  local override="$2"
  echo "WARN (adoption-trade-off accepted by operator: $override): $check" >&2
  WARNINGS=$((WARNINGS + 1))
}

# is_overridden вАФ check –µ—Б–ї–Є component –≤ adoption_overrides skip list
is_overridden() {
  local component="$1"
  echo "$ADOPTION_OVERRIDES_SKIP" | grep -qE "^${component}$"
}

# === Check 1: personas-exist ===
# State-aware: –њ—А–Є foundation_completeness != complete вАФ missing personas.md OK
# –µ—Б–ї–Є spec'–Є –Є—Б–њ–Њ–ї—М–Ј—Г—О—В Mini-persona sections (Tier 1).
check_personas_exist() {
  local f="$DOC_ROOT/personas.md"
  if [ ! -f "$f" ]; then
    if [ "$FOUNDATION_COMPLETENESS" = "complete" ]; then
      log_fail "personas-exist: $f –љ–µ —Б—Г—Й–µ—Б—В–≤—Г–µ—В (foundation_completeness=complete required)"
    elif is_overridden "personas"; then
      log_downgraded "personas-exist: $f –љ–µ —Б—Г—Й–µ—Б—В–≤—Г–µ—В" "personas"
    else
      log_warn "personas-exist: $f –љ–µ —Б—Г—Й–µ—Б—В–≤—Г–µ—В (foundation_completeness=$FOUNDATION_COMPLETENESS вАФ using Tier 1 mini-personas –≤ spec'–∞—Е)"
    fi
    return
  fi
  # –Я—А–Њ–≤–µ—А–Ї–∞ —З—В–Њ –љ–µ placeholder (–љ–µ—В `<вА¶>` –Љ–∞—А–Ї–µ—А–Њ–≤ –љ–∞ > 50% —Б—В—А–Њ–Ї)
  local total=$(wc -l < "$f")
  local placeholders=$(grep -c '<.*>' "$f" || true)
  if [ "$total" -gt 0 ] && [ "$placeholders" -gt $((total / 2)) ]; then
    log_fail "personas-exist: $f –≤—Л–≥–ї—П–і–Є—В –Ї–∞–Ї placeholder (–Љ–љ–Њ–≥–Њ <вА¶> –Љ–∞—А–Ї–µ—А–Њ–≤)"
    return
  fi
  # –Я—А–Њ–≤–µ—А–Ї–∞ –љ–∞–ї–Є—З–Є—П —Е–Њ—В—П –±—Л –Њ–і–љ–Њ–є persona (heuristic: header '## Persona')
  if ! grep -q '^## Persona' "$f"; then
    log_fail "personas-exist: $f –љ–µ —Б–Њ–і–µ—А–ґ–Є—В –љ–Є –Њ–і–љ–Њ–≥–Њ '## Persona' header'–∞"
    return
  fi
  log_ok "personas-exist"
}

# === Check 2: journeys-reference-personas ===
check_journeys_reference_personas() {
  local p="$DOC_ROOT/personas.md"
  local j="$DOC_ROOT/user-journeys.md"
  if [ ! -f "$j" ]; then
    log_fail "journeys-reference-personas: $j –љ–µ —Б—Г—Й–µ—Б—В–≤—Г–µ—В"
    return
  fi
  # Extract persona names (heuristic: '## Persona X:' вЖТ X)
  local personas=$(grep -oE '^## Persona [A-Z0-9]+' "$p" 2>/dev/null | awk '{print $3}' | tr -d ':' || true)
  if [ -z "$personas" ]; then
    log_warn "journeys-reference-personas: –љ–µ —Г–і–∞–ї–Њ—Б—М –Є–Ј–≤–ї–µ—З—М personas –Є–Ј $p (skip)"
    return
  fi
  # –Ъ–∞–ґ–і–∞—П persona –і–Њ–ї–ґ–љ–∞ —Г–њ–Њ–Љ–Є–љ–∞—В—М—Б—П –≤ journeys
  for persona in $personas; do
    if ! grep -q "Persona $persona" "$j"; then
      log_fail "journeys-reference-personas: Persona $persona –≤ $p, –љ–Њ –љ–µ —Г–њ–Њ–Љ—П–љ—Г—В–∞ –≤ $j"
    fi
  done
  log_ok "journeys-reference-personas"
}

# === Check 3: mvp-scope-no-orphans ===
check_mvp_scope_no_orphans() {
  local scope="$DOC_ROOT/mvp-scope.md"
  if [ ! -f "$scope" ]; then
    log_warn "mvp-scope-no-orphans: $scope –љ–µ —Б—Г—Й–µ—Б—В–≤—Г–µ—В (Stage B incomplete)"
    return
  fi
  # Heuristic: F-IDs –≤ —Д–Њ—А–Љ–∞—В–µ `**F01:`, `**F02:` etc.
  local fids=$(grep -oE '\*\*F[0-9]+:' "$scope" | tr -d '*:' || true)
  for fid in $fids; do
    # –Ш—Й–µ–Љ matching spec (–ї—О–±–Њ–є —Д–∞–є–ї, –љ–∞—З–Є–љ–∞—О—Й–Є–є—Б—П –љ–∞ feature topic —Б F-ID)
    if ! ls "$DOC_ROOT/features/"*"_spec.md" 2>/dev/null | xargs grep -l "$fid" >/dev/null 2>&1; then
      # –Ь–Њ–ґ–µ—В –±—Л—В—М deferred
      if grep -A1 "$fid:" "$scope" | grep -qi "deferred"; then
        continue
      fi
      log_warn "mvp-scope-no-orphans: $fid –≤ $scope, –љ–Њ spec –љ–µ –љ–∞–є–і–µ–љ –Є –љ–µ –њ–Њ–Љ–µ—З–µ–љ deferred"
    fi
  done
  log_ok "mvp-scope-no-orphans"
}

# === Check 4: foundational-docs-filled ===
# State-aware: –њ—А–Є foundation_completeness != complete вАФ missing docs –Њ–ґ–Є–і–∞–µ–Љ—Л.
# –Я—А–Є complete вАФ –≤—Б–µ 4 –і–Њ–ї–ґ–љ—Л –±—Л—В—М filled.
check_foundational_docs_filled() {
  local docs=("personas.md" "user-journeys.md" "threat-model.md" "mvp-scope.md")
  for doc in "${docs[@]}"; do
    local f="$DOC_ROOT/$doc"
    local component_name="${doc%.md}"
    if [ ! -f "$f" ]; then
      if [ "$FOUNDATION_COMPLETENESS" = "complete" ]; then
        log_fail "foundational-docs-filled: $f –Њ—В—Б—Г—В—Б—В–≤—Г–µ—В"
      elif is_overridden "$component_name"; then
        log_downgraded "foundational-docs-filled: $f –Њ—В—Б—Г—В—Б—В–≤—Г–µ—В" "$component_name"
      else
        log_warn "foundational-docs-filled: $f –Њ—В—Б—Г—В—Б—В–≤—Г–µ—В (foundation_completeness=$FOUNDATION_COMPLETENESS вАФ using Tier 1 mini-sections)"
      fi
      continue
    fi
    local total=$(wc -l < "$f")
    local placeholders=$(grep -c '<.*>' "$f" || echo 0)
    if [ "$total" -gt 10 ] && [ "$placeholders" -gt $((total / 3)) ]; then
      log_fail "foundational-docs-filled: $f —Б–Њ–і–µ—А–ґ–Є—В –Љ–љ–Њ–≥–Њ placeholder'–Њ–≤ <вА¶> ($placeholders/$total —Б—В—А–Њ–Ї)"
    fi
  done
  log_ok "foundational-docs-filled"
}

# === Check 5: spec-structure ===
check_spec_structure() {
  local required=("## –Ъ–Њ–љ—В–µ–Ї—Б—В" "## User stories" "## –°—Ж–µ–љ–∞—А–Є–Є" "## Non-functional" "## –Э–µ –≤ scope" "## Open questions")
  for spec in "$DOC_ROOT/features/"*_spec.md; do
    [ -e "$spec" ] || continue
    for section in "${required[@]}"; do
      if ! grep -qF "$section" "$spec"; then
        log_fail "spec-structure: $spec missing section '$section'"
      fi
    done
  done
  log_ok "spec-structure"
}

# === Check 6: plan-exists-for-spec ===
check_plan_exists_for_spec() {
  for spec in "$DOC_ROOT/features/"*_spec.md; do
    [ -e "$spec" ] || continue
    local topic=$(basename "$spec" _spec.md)
    local plan="$DOC_ROOT/features/${topic}_plan.md"
    if [ ! -f "$plan" ]; then
      # OK –µ—Б–ї–Є spec –µ—Й—С –љ–µ approved (–љ–µ—В operator-marker)
      if grep -qE "(approved|–Њ–Ї|–њ–Њ–µ—Е–∞–ї–Є)" "$spec"; then
        log_fail "plan-exists-for-spec: $spec –њ–Њ–Љ–µ—З–µ–љ approved, –љ–Њ $plan –Њ—В—Б—Г—В—Б—В–≤—Г–µ—В"
      fi
    fi
  done
  log_ok "plan-exists-for-spec"
}

# === Check 7: rework-has-diff-section / migration-section ===
check_rework_sections() {
  for spec in "$DOC_ROOT/features/"*_spec.v*.md; do
    [ -e "$spec" ] || continue
    if ! grep -qF "## Diff" "$spec"; then
      log_fail "rework-has-diff-section: $spec –љ–µ —Б–Њ–і–µ—А–ґ–Є—В '## Diff' section"
    fi
  done
  for plan in "$DOC_ROOT/features/"*_plan.v*.md; do
    [ -e "$plan" ] || continue
    if ! grep -qF "## Migration" "$plan"; then
      log_fail "rework-has-migration-section: $plan –љ–µ —Б–Њ–і–µ—А–ґ–Є—В '## Migration' section"
    fi
  done
  log_ok "rework-sections"
}

# === Check 8: spec-references-persona ===
# State-aware: –њ—А–Є foundation_completeness != complete вАФ spec –Љ–Њ–ґ–µ—В –Є—Б–њ–Њ–ї—М–Ј–Њ–≤–∞—В—М
# Mini-persona section inline –≤–Љ–µ—Б—В–Њ project-wide persona reference. OK —В–Њ–ґ–µ.
check_spec_references_persona() {
  local personas=$(grep -oE '^## Persona [A-Z0-9]+' "$DOC_ROOT/personas.md" 2>/dev/null | awk '{print $3}' | tr -d ':' || true)
  for spec in "$DOC_ROOT/features/"*_spec.md; do
    [ -e "$spec" ] || continue
    local found=0
    # Check 1: references –Ї project-wide personas
    if [ -n "$personas" ]; then
      for persona in $personas; do
        if grep -q "Persona $persona\|persona $persona" "$spec"; then
          found=1
          break
        fi
      done
    fi
    # Check 2: inline Mini-persona section (Tier 1)
    if [ "$found" -eq 0 ] && grep -qF "## Mini-persona" "$spec"; then
      found=1
    fi
    if [ "$found" -eq 0 ]; then
      log_fail "spec-references-persona: $spec –љ–µ —Б—Б—Л–ї–∞–µ—В—Б—П –љ–Є –љ–∞ –Њ–і–љ—Г persona –Є –љ–µ —Б–Њ–і–µ—А–ґ–Є—В Mini-persona section"
    fi
  done
  log_ok "spec-references-persona"
}

# === Check 9: spec-impact-fields-present (AP-14 enforcement) ===
# –Ъ–∞–ґ–і—Л–є _spec.md –Њ–±—П–Ј–∞–љ —Б–Њ–і–µ—А–ґ–∞—В—М 7 impact –њ–Њ–ї–µ–є –≤ frontmatter:
# 3 operational (AP-13): legal_impact, validation_required, incident_impact
# 4 structural (AP-14): journey_impact, threat_impact, scope_impact, topology_impact
# –Ъ–∞–ґ–і–Њ–µ –њ–Њ–ї–µ –і–Њ–ї–ґ–љ–Њ –Є–Љ–µ—В—М –Ј–љ–∞—З–µ–љ–Є–µ `yes` –Є–ї–Є `no` вАФ –љ–µ –њ—Г—Б—В–Њ, –љ–µ –Њ—В—Б—Г—В—Б—В–≤–Њ–≤–∞—В—М.
# –≠—В–Њ enforce'–Є—В –Њ–±—П–Ј–∞—В–µ–ї—М–љ—Л–є structural read-pass –њ–µ—А–µ–і draft'–Њ–Љ spec'–∞.
check_spec_impact_fields() {
  local required_fields=(
    "legal_impact"
    "validation_required"
    "incident_impact"
    "journey_impact"
    "threat_impact"
    "scope_impact"
    "topology_impact"
  )
  for spec in "$DOC_ROOT/features/"*_spec.md; do
    [ -e "$spec" ] || continue
    # Skip lite-mode: bugfix вАФ –і–ї—П bugfix –Є–Љ–њ–∞–Ї—В—Л –Њ–±—Л—З–љ–Њ —В—А–Є–≤–Є–∞–ї—М–љ—Л (—Б–Љ. AP-13/14 exceptions)
    if grep -qE '^lite-mode:[[:space:]]*bugfix' "$spec"; then
      continue
    fi
    # Extract frontmatter block (–Њ—В –њ–µ—А–≤–Њ–≥–Њ `---` –і–Њ –≤—В–Њ—А–Њ–≥–Њ)
    local frontmatter
    frontmatter=$(awk '/^---$/{c++; next} c==1' "$spec" 2>/dev/null)
    if [ -z "$frontmatter" ]; then
      log_fail "spec-impact-fields-present: $spec –љ–µ —Б–Њ–і–µ—А–ґ–Є—В frontmatter –±–ї–Њ–Ї–∞"
      continue
    fi
    for field in "${required_fields[@]}"; do
      # –Я–Њ–ї–µ –і–Њ–ї–ґ–љ–Њ –њ—А–Є—Б—Г—В—Б—В–≤–Њ–≤–∞—В—М —Б —П–≤–љ—Л–Љ yes|no –Ј–љ–∞—З–µ–љ–Є–µ–Љ
      if ! echo "$frontmatter" | grep -qE "^${field}:[[:space:]]+(yes|no)([[:space:]]|$)"; then
        log_fail "spec-impact-fields-present: $spec вАФ –њ–Њ–ї–µ '${field}' –Њ—В—Б—Г—В—Б—В–≤—Г–µ—В –Є–ї–Є –љ–µ yes/no (AP-14 read-pass –њ—А–Њ–њ—Г—Й–µ–љ)"
      fi
    done
  done
  log_ok "spec-impact-fields-present"
}

# === Check 10: pr-ordering-for-multi-domain (AP-19 enforcement) ===
# –Х—Б–ї–Є spec scenarios –Є–ї–Є –Ъ–Њ–љ—В–µ–Ї—Б—В –Ї–∞—Б–∞—О—В—Б—П вЙ• 2 domains (schema/db + API/backend + UI/frontend),
# frontmatter –Њ–±—П–Ј–∞–љ —Б–Њ–і–µ—А–ґ–∞—В—М `pr_ordering: [...]` —Б —П–≤–љ—Л–Љ —Б–њ–Є—Б–Ї–Њ–Љ.
# –≠—В–Њ enforce'–Є—В AP-19 per-PR atomicity –љ–∞ Step 2 (plan), –љ–µ –љ–∞ Step 4 (coder —Н—Б–Ї–∞–ї–Є—А—Г–µ—В –њ–Њ–Ј–і–љ–Њ).
check_pr_ordering_for_multi_domain() {
  for spec in "$DOC_ROOT/features/"*_spec.md; do
    [ -e "$spec" ] || continue
    # Skip lite-mode: bugfix / small-fix вАФ –Њ–±—Л—З–љ–Њ single-domain
    if grep -qE '^lite-mode:[[:space:]]*(bugfix|small-fix)' "$spec"; then
      continue
    fi
    # Extract domain hints –Є–Ј spec body (–њ–Њ—Б–ї–µ frontmatter вАФ –і–≤–∞ `---`)
    local body
    body=$(awk '/^---$/{c++; next} c>=2' "$spec" 2>/dev/null)
    # Detect domains: regex –њ—А–Њ—В–Є–≤ –Њ–±—Л—З–љ—Л—Е indicator'–Њ–≤
    local domains=0
    if echo "$body" | grep -qiE '\b(schema|migration|database|—В–∞–±–ї–Є—Ж|–Ї–Њ–ї–Њ–љ–Ї|–Є–љ–і–µ–Ї—Б|sql)'; then
      domains=$((domains + 1))
    fi
    if echo "$body" | grep -qiE '\b(API|endpoint|route|REST|GraphQL|webhook|RPC|–Ї–Њ–љ—В—А–∞–Ї—В)'; then
      domains=$((domains + 1))
    fi
    if echo "$body" | grep -qiE '\b(UI|page|view|form|component|–Ї–Њ–Љ–њ–Њ–љ–µ–љ—В|—Б—В—А–∞–љ–Є—Ж|—Д–Њ—А–Љ)'; then
      domains=$((domains + 1))
    fi
    # Multi-domain detected вЖТ pr_ordering –Њ–±—П–Ј–∞—В–µ–ї–µ–љ
    if [ "$domains" -ge 2 ]; then
      local frontmatter
      frontmatter=$(awk '/^---$/{c++; next} c==1' "$spec" 2>/dev/null)
      # Frontmatter has pr_ordering: [<list>] (–љ–µ null, –љ–µ –њ—Г—Б—В–Њ)
      if ! echo "$frontmatter" | grep -qE '^pr_ordering:[[:space:]]*\['; then
        log_fail "pr-ordering-for-multi-domain: $spec touches ${domains} domains, –љ–Њ frontmatter –љ–µ —Б–Њ–і–µ—А–ґ–Є—В 'pr_ordering: [...]' (AP-19)"
      fi
    fi
  done
  log_ok "pr-ordering-for-multi-domain"
}

# === Check 11: security-spec-cites-standard (conditional) ===
check_security_spec_cites_standard() {
  for spec in "$DOC_ROOT/features/"*_spec.md; do
    [ -e "$spec" ] || continue
    # Heuristic: spec —Б—З–Є—В–∞–µ—В—Б—П security-touching, –µ—Б–ї–Є –≤ –љ—С–Љ —Г–њ–Њ–Љ–Є–љ–∞–µ—В—Б—П auth/crypto/PII/payments/session
    if grep -qiE 'auth|crypto|PII|payment|session|secret' "$spec"; then
      # –Ф–Њ–ї–ґ–љ–∞ –±—Л—В—М Security invariants —Б–µ–Ї—Ж–Є—П —Б OWASP/CWE/ASVS —Б—Б—Л–ї–Ї–∞–Љ–Є
      if ! grep -qF "## Security invariants" "$spec"; then
        log_warn "security-spec-cites-standard: $spec –≤—Л–≥–ї—П–і–Є—В security-touching, –љ–Њ –±–µ–Ј '## Security invariants' —Б–µ–Ї—Ж–Є–Є"
        continue
      fi
      if ! grep -qiE 'OWASP|CWE|ASVS' "$spec"; then
        log_fail "security-spec-cites-standard: $spec —Г–њ–Њ–Љ–Є–љ–∞–µ—В security-touching, –љ–Њ –љ–µ —Б—Б—Л–ї–∞–µ—В—Б—П –љ–∞ OWASP/CWE/ASVS —Б—В–∞–љ–і–∞—А—В—Л –≤ Security invariants"
      fi
    fi
  done
  log_ok "security-spec-cites-standard"
}

# === Main ===
case "${1:-all}" in
  --staged-only)
    # TODO: –і–ї—П pre-commit hook вАФ —В–Њ–ї—М–Ї–Њ staged files
    # –Э–∞ v0 вАФ –њ—А–Њ—Б—В–Њ run all
    ;;
  --check)
    shift
    if [ -z "${1:-}" ]; then
      echo "Usage: $0 --check <check-name>" >&2
      exit 2
    fi
    "check_${1//-/_}"
    ;;
  all|*)
    check_personas_exist
    check_journeys_reference_personas
    check_mvp_scope_no_orphans
    check_foundational_docs_filled
    check_spec_structure
    check_plan_exists_for_spec
    check_rework_sections
    check_spec_references_persona
    check_spec_impact_fields
    check_pr_ordering_for_multi_domain
    check_security_spec_cites_standard
    ;;
esac

echo ""
echo "Summary: $FAILED FAILED, $WARNINGS WARNINGS"

if [ "$FAILED" -gt 0 ]; then
  exit 1
fi
exit 0
