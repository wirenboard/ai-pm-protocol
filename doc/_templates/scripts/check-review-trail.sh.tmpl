#!/usr/bin/env bash
# scripts/check-review-trail.sh
# Layer 4 / Layer 5 enforcement: проверяет наличие review-trail для текущей ветки.
#
# Используется в двух местах:
#   1. .git/hooks/pre-push (Layer 4) — блокирует git push без review-trail
#   2. .github/workflows/check-review-trail.yml (Layer 5) — блокирует merge PR без trail
#
# Usage:
#   scripts/check-review-trail.sh [branch-name]
#   - branch-name (опционально): имя ветки. Default: текущая (git rev-parse --abbrev-ref HEAD).
#
# Exit codes:
#   0 — trail валиден (verdict approve | approve-with-comments) ИЛИ override-маркер
#   1 — trail отсутствует / verdict request-changes / неизвестный verdict
#
# Override-маркеры (в HEAD commit body, на отдельной строке):
#   [skip-review]                — для trivial chore (typo / dep bump)
#   [review-override: <reason>]  — для verdict=request-changes (deferred fix)
#
# Дизайн: review всегда происходит локально через reviewer-agent ДО push'а.
# Trail — либо committed `doc/features/<topic>_review.md` (для feature/<topic>),
# либо `.ai-pm/.reviews/<branch>.json` (для chore / docs / template-extension).
# Hook читает только локальные файлы — никакой зависимости от GitHub/GitLab API.

set -e

BRANCH="${1:-$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo '')}"
if [ -z "$BRANCH" ]; then
  echo "ERROR: не удалось определить ветку (git rev-parse failed?)." >&2
  exit 1
fi

REPO_ROOT=$(git rev-parse --show-toplevel 2>/dev/null || echo ".")
HEAD_BODY=$(git -C "$REPO_ROOT" log -1 --pretty=%B 2>/dev/null || echo "")

# === Check 1: Skip-marker (line-anchored) ===
# Только строка целиком `[skip-review]` (с возможным trailing whitespace) — explicit override.
# Упоминания внутри prose не триггерят skip.
if echo "$HEAD_BODY" | grep -qE '^\[skip-review\][[:space:]]*$'; then
  echo "INFO: HEAD commit имеет [skip-review] маркер — review enforcement пропущен." >&2
  echo "Используется для trivial chore (typo-fix, dep bump). См. AP-16." >&2
  exit 0
fi

# parse_verdict_md: извлекает verdict из committed _review.md.
# Формат: `**Verdict:** approve | approve-with-comments | request-changes` в первых 50 строках.
# Регистронезависимо. Возвращает на stdout одно из: approve | approve-with-comments | request-changes | unknown
parse_verdict_md() {
  local file="$1"
  local line
  line=$(head -n 50 "$file" | grep -iE '^\*\*Verdict:\*\*[[:space:]]*(approve-with-comments|approve|request-changes|changes-requested)' | head -1 || true)
  case "$line" in
    *[Aa]pprove-with-comments*) echo "approve-with-comments" ;;
    *[Rr]equest-changes*|*[Cc]hanges-requested*) echo "request-changes" ;;
    *[Aa]pprove*) echo "approve" ;;
    *) echo "unknown" ;;
  esac
}

# parse_verdict_json: извлекает .verdict из local trace JSON.
parse_verdict_json() {
  local file="$1"
  if command -v jq >/dev/null 2>&1; then
    jq -r '.verdict // "unknown"' "$file" 2>/dev/null || echo "unknown"
  else
    grep -oE '"verdict"[[:space:]]*:[[:space:]]*"[^"]+"' "$file" 2>/dev/null \
      | sed -E 's/.*"([^"]+)"$/\1/' | head -1 || echo "unknown"
  fi
}

# block_on_verdict: если verdict не green — exit 1.
# Operator-override через [review-override: <reason>] в HEAD commit body.
block_on_verdict() {
  local verdict="$1"
  local source="$2"
  case "$verdict" in
    approve|approve-with-comments)
      return 0
      ;;
    request-changes|changes-requested)
      if echo "$HEAD_BODY" | grep -qE '^\[review-override:[[:space:]]*[^]]+\][[:space:]]*$'; then
        REASON=$(echo "$HEAD_BODY" | grep -oE '^\[review-override:[[:space:]]*[^]]+\]' | sed -E 's/^\[review-override:[[:space:]]*//; s/\]$//')
        echo "INFO: operator-override через [review-override: $REASON]" >&2
        echo "      Verdict был '$verdict', но оператор явно принимает push. Override visible в git log." >&2
        return 0
      fi
      echo "" >&2
      echo "BLOCKED: review verdict = '$verdict' (источник: $source)." >&2
      echo "" >&2
      echo "Push с unresolved findings нарушает AP-16: review должен быть зелёным ДО push'а." >&2
      echo "" >&2
      echo "Опции:" >&2
      echo "  (а) Зафиксить findings — применить fix'ы, перезапустить reviewer-agent," >&2
      echo "      когда verdict станет approve — повторить git push" >&2
      echo "  (б) Operator-override deferred — оператор явно деклирует trade-off:" >&2
      echo "      добавить '[review-override: <reason>]' на отдельной строке HEAD commit body" >&2
      echo "      (через git commit --amend), затем git push" >&2
      echo "Override без explicit instruction оператора запрещён (AP-16, AP-3 operator-gate)." >&2
      echo "" >&2
      exit 1
      ;;
    unknown|*)
      echo "" >&2
      echo "BLOCKED: не удалось распознать verdict в review-trail (источник: $source)." >&2
      echo "Ожидаемый формат:" >&2
      echo "  • Committed _review.md — строка '**Verdict:** approve' (или approve-with-comments / request-changes)" >&2
      echo "    в первых 50 строках файла" >&2
      echo "  • Local trace JSON — поле 'verdict' со значением approve | approve-with-comments | request-changes" >&2
      echo "" >&2
      exit 1
      ;;
  esac
}

# === Check 2: Committed _review.md для Stage E feature ===
# Поддерживаются оба prefix'а: feature/<topic> (AP-canonical) и feat/<topic> (popular practice).
#
# Smart fallback (Bug #1 из protocol-minors-2026-05-25):
#   (a) Сначала branch-suffix lookup — `<branch-suffix>_review.md` (current/canonical behavior).
#   (b) Если не нашли — topic-based fallback: читаем `topic:` из spec frontmatter
#       `<branch-suffix>_spec.md` и ищем `<topic>_review.md`. Покрывает случай переименования
#       (branch остался под старым именем, spec topic — новое).
# Invariant: branch-suffix всегда takes precedence над topic-based — чтобы предсказуемо
# вело себя для типичного case'а (branch suffix = spec topic).
TOPIC=""
case "$BRANCH" in
  feature/*) TOPIC="${BRANCH#feature/}" ;;
  feat/*)    TOPIC="${BRANCH#feat/}" ;;
esac

# read_spec_topic: читает `topic:` field из YAML frontmatter spec'а (первый матч).
# Возвращает значение topic'а на stdout (пустая строка если не нашёл).
read_spec_topic() {
  local spec="$1"
  if [ ! -f "$spec" ]; then
    return 0
  fi
  # Только первый match — frontmatter в начале файла. Trim trailing whitespace.
  grep -E '^topic:[[:space:]]*' "$spec" 2>/dev/null \
    | head -1 \
    | sed -E 's/^topic:[[:space:]]*//; s/[[:space:]]+$//'
}

if [ -n "$TOPIC" ]; then
  # (a) Branch-suffix lookup — primary path.
  for review_path in "$REPO_ROOT/doc/features/${TOPIC}_review.md" \
                     "$REPO_ROOT/.ai-pm/doc/features/${TOPIC}_review.md"; do
    if [ -f "$review_path" ]; then
      VERDICT=$(parse_verdict_md "$review_path")
      block_on_verdict "$VERDICT" "$review_path"
      exit 0
    fi
  done

  # (b) Topic-based fallback — если branch-suffix review не найден,
  # пробуем извлечь `topic:` из spec frontmatter и искать review под этим именем.
  SPEC_TOPIC=""
  for spec_path in "$REPO_ROOT/doc/features/${TOPIC}_spec.md" \
                   "$REPO_ROOT/.ai-pm/doc/features/${TOPIC}_spec.md"; do
    if [ -f "$spec_path" ]; then
      SPEC_TOPIC=$(read_spec_topic "$spec_path")
      break
    fi
  done
  if [ -n "$SPEC_TOPIC" ] && [ "$SPEC_TOPIC" != "$TOPIC" ]; then
    for review_path in "$REPO_ROOT/doc/features/${SPEC_TOPIC}_review.md" \
                       "$REPO_ROOT/.ai-pm/doc/features/${SPEC_TOPIC}_review.md"; do
      if [ -f "$review_path" ]; then
        echo "INFO: branch suffix '$TOPIC' не имеет review-файла; найден '${SPEC_TOPIC}_review.md' через spec frontmatter topic." >&2
        echo "      Подсказка: при переименовании topic'а стоит переименовать и feature-branch." >&2
        VERDICT=$(parse_verdict_md "$review_path")
        block_on_verdict "$VERDICT" "$review_path"
        exit 0
      fi
    done
  fi
fi

# === Check 3: Local trace file ===
TRACE_NAME=$(echo "$BRANCH" | tr '/' '-')
TRACE_FILE="$REPO_ROOT/.ai-pm/.reviews/${TRACE_NAME}.json"
if [ -f "$TRACE_FILE" ]; then
  VERDICT=$(parse_verdict_json "$TRACE_FILE")
  block_on_verdict "$VERDICT" "$TRACE_FILE"
  exit 0
fi

# === Нет trail вообще — последний шанс: explicit operator-override ===
if echo "$HEAD_BODY" | grep -qE '^\[review-override:[[:space:]]*[^]]+\][[:space:]]*$'; then
  REASON=$(echo "$HEAD_BODY" | grep -oE '^\[review-override:[[:space:]]*[^]]+\]' | sed -E 's/^\[review-override:[[:space:]]*//; s/\]$//')
  echo "INFO: operator-override через [review-override: $REASON] (review-trail отсутствует)." >&2
  exit 0
fi

# === Иначе — block ===
echo "" >&2
echo "BLOCKED: для ветки '$BRANCH' не найден review-trail." >&2
echo "" >&2
echo "Review всегда происходит локально через reviewer-agent ДО git push." >&2
echo "Перед push'ом нужно одно из:" >&2
echo "  (а) Запустить reviewer-agent (см. .claude/agents/reviewer.md), который сохранит:" >&2
echo "      • Stage E (branch feature/<topic>): committed 'doc/features/<topic>_review.md'" >&2
echo "        с '**Verdict:** approve' (или approve-with-comments) в первых 50 строках" >&2
echo "      • Chore / docs / template-extension: '.ai-pm/.reviews/<branch>.json'" >&2
echo "        с полем 'verdict' = approve | approve-with-comments" >&2
echo "  (б) Для trivial chore (typo-fix, dep bump) — добавить '[skip-review]' маркер" >&2
echo "      на отдельной строке HEAD commit body (explicit override, visible в git log)" >&2
echo "  (в) Explicit operator-override — '[review-override: <reason>]' на отдельной строке" >&2
echo "      HEAD commit body (для bootstrap / chicken-egg / declared trade-off)" >&2
echo "" >&2
echo "См. AP-16 в doc/anti-patterns.md." >&2
echo "" >&2
exit 1
