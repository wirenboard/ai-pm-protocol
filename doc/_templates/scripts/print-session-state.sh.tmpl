#!/usr/bin/env bash
# scripts/print-session-state.sh
# SessionStart hook — печатает текущее содержимое .ai-pm/.session-state.md
# в stderr, чтобы Claude увидел координаты «где мы» в первые секунды session'и
# без сканирования веток / PR / features/.
#
# Если файла нет — печатает fallback с инструкцией для AI (восстановить
# через git branch --show-current + gh pr list + scan doc/features/).
#
# Контракт:
#   - Output в stderr (SessionStart hook output попадает к AI как session bootstrap).
#   - Exit 0 всегда — non-blocking, информирует только.
#   - Не пишет в stdout (зарезервировано для возможной future structured output).
#
# Smoke-test: bash scripts/print-session-state.sh
# Full test suite: bash scripts/tests/session-state-smoke.sh

set -u

STATE=".ai-pm/.session-state.md"

if [ -f "$STATE" ]; then
  {
    echo ""
    echo "=== Session state (.ai-pm/.session-state.md) ==="
    echo ""
    cat "$STATE"
    echo ""
  } >&2
else
  {
    echo ""
    echo "=== Session state ==="
    echo ""
    echo "Файл .ai-pm/.session-state.md отсутствует — session state не сохранён."
    echo "AI: восстанови контекст через:"
    echo "  - git branch --show-current      # текущая feature ветка"
    echo "  - gh pr list --state open        # активные PR series"
    echo "  - ls doc/features/*_spec.md      # in-progress фичи (spec без plan)"
    echo ""
    echo "После первого Write/Edit в feature artifact PostToolUse hook создаст файл."
    echo ""
  } >&2
fi

exit 0
