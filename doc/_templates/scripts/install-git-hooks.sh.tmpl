#!/usr/bin/env bash
# scripts/install-git-hooks.sh
# Устанавливает git hooks для local enforcement (Layer 4).
# Bootstrap-agent запускает на Stage D.

set -e

HOOK_DIR=".git/hooks"
if [ ! -d "$HOOK_DIR" ]; then
  echo "ERROR: $HOOK_DIR не существует. Это git repo?" >&2
  exit 1
fi

# === pre-commit hook ===
cat > "$HOOK_DIR/pre-commit" <<'HOOK'
#!/usr/bin/env bash
# Pre-commit: lint + format + secret-scan + conventional commit check.

set -e

# 0. Verify git identity set (AP-10)
if [ -z "$(git config user.email)" ] || [ -z "$(git config user.name)" ]; then
  echo "BLOCKED: git config user.email и user.name должны быть set'нуты." >&2
  echo "Run:" >&2
  echo "  git config user.email <your-email>" >&2
  echo "  git config user.name <Your Name>" >&2
  echo "См. anti-pattern AP-10." >&2
  exit 1
fi

# 1. Запретить коммит в main/master напрямую (защита от случайных коммитов)
BRANCH=$(git rev-parse --abbrev-ref HEAD)
if [ "$BRANCH" = "main" ] || [ "$BRANCH" = "master" ]; then
  echo "BLOCKED: direct commit в $BRANCH запрещён. Создай feature branch." >&2
  exit 1
fi

# 2. Запустить linters (stack-specific, генерируется на Stage D под выбранный стек)
# Адаптируется bootstrap-agent'ом. Default — попытка запустить generic commands.
if [ -f "package.json" ] && command -v pnpm >/dev/null; then
  pnpm run lint:fix 2>/dev/null || true
  pnpm run format 2>/dev/null || true
elif [ -f "pyproject.toml" ] && command -v ruff >/dev/null; then
  ruff check . --fix 2>/dev/null || true
  ruff format . 2>/dev/null || true
elif [ -f "go.mod" ] && command -v gofmt >/dev/null; then
  gofmt -w . 2>/dev/null || true
fi

# 3. Secret scanning (gitleaks или эквивалент)
if command -v gitleaks >/dev/null; then
  gitleaks protect --staged --redact --no-banner --exit-code 1
fi

# 4. Spec discipline check (если установлен).
# Bootstrap-agent на Stage D генерирует один из .sh / .py / .ts вариантов по стеку проекта.
for candidate in scripts/check-spec-discipline scripts/check-spec-discipline.sh scripts/check-spec-discipline.py scripts/check-spec-discipline.ts; do
  if [ -x "$candidate" ]; then
    "$candidate" --staged-only
    break
  fi
done

# 5. Skip-reprompts warning (non-blocking) — печатает expired skip'ы для напоминания
if [ -x "scripts/check-skip-reprompts.sh" ]; then
  scripts/check-skip-reprompts.sh || true
fi

exit 0
HOOK
chmod +x "$HOOK_DIR/pre-commit"

# === commit-msg hook ===
cat > "$HOOK_DIR/commit-msg" <<'HOOK'
#!/usr/bin/env bash
# Commit-msg: проверка Conventional Commits 1.0 формата.

MSG_FILE="$1"
FIRST_LINE=$(head -n1 "$MSG_FILE")

# Pattern: type(scope)?!?: subject
PATTERN='^(feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert)(\([a-z0-9-]+\))?!?: .+'

if ! echo "$FIRST_LINE" | grep -qE "$PATTERN"; then
  echo "BLOCKED: commit message не follows Conventional Commits 1.0." >&2
  echo "Format: <type>(<scope>)?!?: <subject>" >&2
  echo "Types: feat, fix, docs, style, refactor, perf, test, build, ci, chore, revert" >&2
  echo "Examples:" >&2
  echo "  feat(auth): add OAuth login flow" >&2
  echo "  fix: handle null in user query" >&2
  echo "  feat!: drop legacy webhook format" >&2
  echo "See development-protocol.md § 14." >&2
  exit 1
fi

exit 0
HOOK
chmod +x "$HOOK_DIR/commit-msg"

# === pre-push hook ===
# Два независимых блока:
#   1. Hard block на main / master push (клиентский эквивалент branch protection
#      для GitHub free private plan'ов без серверной protection).
#   2. Review-trail check для feature/<topic> push'ей (AP-16 Layer 4 enforcement).
#      Блокирует push если нет review-файла / verdict=request-changes / unknown verdict.
#      Override-маркеры [skip-review] / [review-override:] в HEAD commit body — поддерживаются.
# § 14.7 development-protocol запрещает обход через --no-verify.
cat > "$HOOK_DIR/pre-push" <<'HOOK'
#!/usr/bin/env bash
# Pre-push:
#  (1) hard block на main / master push
#  (2) review-trail enforcement для feature/<topic> push'ей (AP-16)

protected_pattern='refs/heads/(main|master)'

while read -r local_ref local_sha remote_ref remote_sha; do
  # (1) main / master block
  if echo "$remote_ref" | grep -qE "^$protected_pattern$"; then
    echo "" >&2
    echo "BLOCKED: прямой push в $remote_ref запрещён." >&2
    echo "" >&2
    echo "Согласно development-protocol.md § 14 — только feature/<topic> ветки + PR + squash & merge." >&2
    echo "Создай ветку, открой PR через 'gh pr create', merge через PR UI после reviewer-agent approval." >&2
    echo "" >&2
    echo "§ 14.7 development-protocol запрещает обход через --no-verify." >&2
    echo "" >&2
    exit 1
  fi

  # (2) review-trail для feature/<topic> push'ей
  case "$remote_ref" in
    refs/heads/feature/*|refs/heads/feat/*|refs/heads/chore/*|refs/heads/docs/*|refs/heads/fix/*|refs/heads/refactor/*)
      BRANCH="${remote_ref#refs/heads/}"
      if [ -x "scripts/check-review-trail.sh" ]; then
        if ! scripts/check-review-trail.sh "$BRANCH"; then
          # check-review-trail.sh уже напечатал детали в stderr
          exit 1
        fi
      fi
      ;;
  esac
done

exit 0
HOOK
chmod +x "$HOOK_DIR/pre-push"

echo "Git hooks installed:"
echo "  - pre-commit: lint, format, secret-scan, spec-discipline"
echo "  - commit-msg: Conventional Commits 1.0 enforcement"
echo "  - pre-push: hard block на main/master + review-trail enforcement (AP-16) для feature/chore/docs/fix push'ей"
