#!/bin/sh
# ai-dev:launch — OPTIONAL project launcher (a drop-in for `claude`, run from the
# project root). Generated by the installer. You only NEED it for multi-model +
# proxy, or a per-project claude profile (launch.configDir) — a plain single-model
# project can keep launching `claude` (or your own wrapper) directly. The engine
# decides direct-vs-router and layers the launch env; see README `## Multi-model
# routing` and src/adapter/README.md `### The launcher`.
#   ./.ai-dev/launch [claude args…]   normal launch (direct, or through the proxy)
#   ./.ai-dev/launch --proxy          foreground proxy only — prints the URL, no claude
exec node "src/adapter/router-launch.mjs" "$@"
